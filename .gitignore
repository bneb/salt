# =============================================================================
# Salt / Lattice — .gitignore
# =============================================================================

# ─── Build artifacts ─────────────────────────────────────────────────────────
*.o
*.a
*.so
*.dylib
*.mlir
*.ll
*.s
!kernel/arch/**/*.S
*.bc
*.testmlir
build/

# ─── Bazel ───────────────────────────────────────────────────────────────────
bazel-*

# ─── Rust / Cargo ────────────────────────────────────────────────────────────
target/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/

# ─── Profiling & coverage ───────────────────────────────────────────────────
*.profraw
*.profdata
coverage_report/
coverage_artifacts/
coverage_summary*.txt
html_report/
**/fuzz/artifacts/
**/fuzz/corpus/

# ─── Editors & OS ───────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store

# ─── VS Code extension build artifacts ──────────────────────────────────────
tools/salt-lsp/editors/vscode/node_modules/
tools/salt-lsp/editors/vscode/out/
tools/salt-lsp/editors/vscode/*.vsix
tools/salt-lsp/editors/vscode/package-lock.json

# ─── Logs & temporary output ────────────────────────────────────────────────
*.log
*.bak
compile_error.txt
output.txt
help.txt
*_symbols.txt

