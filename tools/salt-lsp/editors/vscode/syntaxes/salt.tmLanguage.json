{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Salt",
    "scopeName": "source.salt",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#fstrings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#storage"
        },
        {
            "include": "#types"
        },
        {
            "include": "#attributes"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#constants"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.salt",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.salt",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.salt",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.salt",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "fstrings": {
            "patterns": [
                {
                    "name": "string.interpolated.salt",
                    "begin": "f\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.salt",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.interpolation.salt",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                {
                                    "include": "source.salt"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.salt",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.salt",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.float.salt",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
                },
                {
                    "name": "constant.numeric.integer.salt",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.salt",
                    "match": "\\b(if|else|for|while|loop|match|return|break|continue|in)\\b"
                },
                {
                    "name": "keyword.declaration.salt",
                    "match": "\\b(fn|let|mut|struct|enum|impl|trait|concept|extern|const|package|use|pub|move|unsafe)\\b"
                },
                {
                    "name": "keyword.verification.salt",
                    "match": "\\b(requires|ensures|invariant)\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.type.salt",
                    "match": "\\b(fn|struct|enum|trait|concept|impl)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.primitive.salt",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool)\\b"
                },
                {
                    "name": "entity.name.type.stdlib.salt",
                    "match": "\\b(Ptr|Result|Option|Status|String|StringView|Vec|HashMap|Arena|DirHandle)\\b"
                },
                {
                    "name": "entity.name.type.user.salt",
                    "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.salt",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
                    "captures": {
                        "0": {
                            "name": "entity.other.attribute-name.salt"
                        }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.salt",
                    "match": "(\\->|=>|::|\\.\\.=?|\\?|&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.comparison.salt",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.salt",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.assignment.salt",
                    "match": "(=|\\+=|-=|\\*=|/=)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.salt",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.salt"
                        }
                    }
                },
                {
                    "name": "meta.function.definition.salt",
                    "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.salt"
                        },
                        "2": {
                            "name": "entity.name.function.definition.salt"
                        }
                    }
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.salt",
                    "match": "\\b(true|false|null)\\b"
                },
                {
                    "name": "variable.language.salt",
                    "match": "\\b(self)\\b"
                }
            ]
        }
    }
}