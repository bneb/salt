{
    "name": "salt-language",
    "displayName": "Salt Language",
    "description": "Salt language support — semantic tokens, go-to-definition, find-references, document symbols, Z3 contract hover, code actions, and in-memory diagnostics",
    "icon": "icon.png",
    "version": "0.3.0",
    "license": "MIT",
    "publisher": "salt-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/salt-lang/keuos"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "salt",
                "aliases": [
                    "Salt",
                    "salt"
                ],
                "extensions": [
                    ".salt"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "salt",
                "scopeName": "source.salt",
                "path": "./syntaxes/salt.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "Salt Language",
            "properties": {
                "salt.lspPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the salt-lsp binary. Auto-detected if blank."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}