// tests/test_framework.salt — Tests for the @test runner
// Rewritten with a standard main entry point.
package main

extern fn exit(code: i32);

fn assert(cond: bool) {
    if !cond {
        println("ASSERTION FAILED");
        exit(1);
    }
}

fn test_arithmetic() {
    let x = 2 + 3;
    assert(x == 5);
    println("  [PASS] test_arithmetic");
}

fn test_boolean_logic() {
    assert(true);
    assert(!false);
    assert(1 < 2);
    println("  [PASS] test_boolean_logic");
}

fn test_string_compare() {
    let a: i64 = 42;
    assert(a == 42);
    println("  [PASS] test_string_compare");
}

fn test_loop_sum() {
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < 10 {
        sum = sum + i;
        i = i + 1;
    }
    assert(sum == 45);
    println("  [PASS] test_loop_sum");
}

fn main() -> i32 {
    println("=== Framework Tests ===");
    test_arithmetic();
    test_boolean_logic();
    test_string_compare();
    test_loop_sum();
    println("=== All framework tests passed ===");
    return 0;
}
