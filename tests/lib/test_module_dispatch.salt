// Test: Module namespace method dispatch in --lib mode
// Validates that module-qualified method calls resolve correctly
// when compiled with --lib flag.
//
// Rewrote to avoid kernel.core.io dependency (requires bare-metal).
// Uses a mock module-namespace call pattern instead.

package test.module_dispatch

import std.core.ptr.Ptr

pub fn mock_outb(port: u32, value: u8) {
    // In production, this would be kernel.core.io.outb
    // which emits an x86 OUT instruction.
    // Here we just verify the dispatch resolves.
}

pub fn test_dispatch() {
    // Module-namespace call (not method-on-struct)
    mock_outb(0x3F8, 0x41);
}

pub fn main() {}
