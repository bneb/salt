// =============================================================================
// Minimal freestanding Salt program — zero runtime dependencies.
// =============================================================================
// This is the simplest possible userspace program for the KeuOS kernel.
// It uses no println(), no exit(), no I/O — just pure computation.
// The kernel's ELF loader will call main() and read the return code.

package main

global ANSWER: i64 = 42;
global FACTOR: i64 = 2;

fn main() -> i32 {
    let result = ANSWER * FACTOR;
    if result == 84 {
        return 0;  // success
    }
    return 1;  // failure
}
