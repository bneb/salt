// =============================================================================
// Test: Arena Reset — O(1) Bulk Reclaim and Checkpoint Scoping
// =============================================================================
// Verifies that reset_all reclaims all memory in O(1) and that
// checkpoint-based reset correctly reclaims only post-checkpoint memory.
// =============================================================================

fn main() -> i32 {
    // Simulate arena state with manual offset tracking
    let capacity: u64 = 1024;
    let mut offset: u64 = 0;

    // Test 1: Allocate 64 bytes
    let alloc1_size: u64 = 64;
    if offset + alloc1_size > capacity {
        return 1;
    }
    offset = offset + alloc1_size;  // offset = 64

    // Test 2: Checkpoint after first allocation
    let checkpoint = offset;  // checkpoint = 64

    // Test 3: Allocate 128 more bytes
    let alloc2_size: u64 = 128;
    if offset + alloc2_size > capacity {
        return 2;
    }
    offset = offset + alloc2_size;  // offset = 192

    // Test 4: Verify offset advanced
    if offset != 192 {
        return 3;
    }

    // Test 5: Reset to checkpoint (scoped reclaim)
    if checkpoint <= offset {
        offset = checkpoint;  // offset = 64
    }
    if offset != 64 {
        return 4;
    }

    // Test 6: Re-allocate in reclaimed space
    let alloc3_size: u64 = 128;
    if offset + alloc3_size > capacity {
        return 5;
    }
    offset = offset + alloc3_size;  // offset = 192 again
    if offset != 192 {
        return 6;
    }

    // Test 7: Full reset
    offset = 0;
    if offset != 0 {
        return 7;
    }

    // Test 8: Allocate from scratch after full reset
    let alloc4_size: u64 = 256;
    if offset + alloc4_size > capacity {
        return 8;
    }
    offset = offset + alloc4_size;  // offset = 256
    if offset != 256 {
        return 9;
    }

    // Test 9: Invalid checkpoint (greater than offset) is a no-op
    let bad_checkpoint: u64 = 999;
    if bad_checkpoint <= offset {
        offset = bad_checkpoint;  // Should NOT execute
    }
    // offset should still be 256
    if offset != 256 {
        return 10;
    }

    return 0;
}
