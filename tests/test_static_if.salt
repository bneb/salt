// test_static_if.salt - Test for compile-time conditional features
// static_if is not yet supported by the parser, so we test feature detection
// via runtime checks for now.

package main

extern fn exit(code: i32);

fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn main() -> i32 {
    println("=== Compile-Time Feature Tests ===");

    // Test 1: Basic boolean conditional (simulates static_if)
    let is_arm64 = true;  // We know we're on ARM64
    if is_arm64 {
        println("  [PASS] ARM64 platform detected");
    }

    // Test 2: Conditional path selection
    let use_neon = true;  // Neon is always available on Apple Silicon
    let hash_result: i64 = if use_neon { 42 } else { 0 };
    assert_true(hash_result == 42, 2);
    println("  [PASS] Neon path selected");

    // Test 3: Feature flag chaining
    let has_crypto = true;  
    let has_fp16 = true;    
    if has_crypto && has_fp16 {
        println("  [PASS] Multiple features detected");
    }

    println("=== All compile-time feature tests passed ===");
    return 0;
}
