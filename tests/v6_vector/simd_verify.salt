package tests.simd_verify;

import std.simd.{Simd, f32x4};

// Verifies SIMD intrinsic resolution for v_broadcast, v_add, and v_mul.

fn main() -> i32 {
    let scalar: f32 = 1.0;
    let v1: Simd<f32, 4> = v_broadcast(scalar); 
    let v2: Simd<f32, 4> = v_broadcast(2.0);
    
    let sum = v_add(v1, v2);
    let prod = v_mul(sum, v1);
    
    return 0;
}
