// =============================================================================
// test_syn_cookie.salt — SYN Cookie + SipHash Integration Tests
// =============================================================================
//
// Validates:
//   1. SipHash-2-4 known vectors (deterministic)
//   2. Cookie round-trip: generate → validate returns true
//   3. Cookie validation fails on tampered input
//   4. Cookies are non-zero (the Z3 contract in production)
//   5. Different tuples → different cookies
//   6. MSS encoding round-trip
//
// Run: ./scripts/run_test.sh tests/test_syn_cookie.salt
// =============================================================================

package main
import std.core.str.StringView;


import std.core.ptr.Ptr;

extern fn malloc(size: i64) -> Ptr<u8>;

// ============================================================================
// Inline SipHash-2-4 (mirrors basalt/crypto/siphash.salt)
// ============================================================================

@inline
fn rotl64(x: u64, n: i32) -> u64 {
    return (x << n) | (x >> (64 - n));
}

struct SipState {
    v0: u64,
    v1: u64,
    v2: u64,
    v3: u64,
}

@inline
fn sip_round(s: &mut SipState) {
    s.v0 = s.v0 + s.v1;
    s.v1 = rotl64(s.v1, 13);
    s.v1 = s.v1 ^ s.v0;
    s.v0 = rotl64(s.v0, 32);
    s.v2 = s.v2 + s.v3;
    s.v3 = rotl64(s.v3, 16);
    s.v3 = s.v3 ^ s.v2;
    s.v0 = s.v0 + s.v3;
    s.v3 = rotl64(s.v3, 21);
    s.v3 = s.v3 ^ s.v0;
    s.v2 = s.v2 + s.v1;
    s.v1 = rotl64(s.v1, 17);
    s.v1 = s.v1 ^ s.v2;
    s.v2 = rotl64(s.v2, 32);
}

fn siphash_2_4(k0: u64, k1: u64, m0: u64, m1: u64) -> u64 {
    let mut s = SipState {
        v0: k0 ^ 0x736f6d6570736575,
        v1: k1 ^ 0x646f72616e646f6d,
        v2: k0 ^ 0x6c7967656e657261,
        v3: k1 ^ 0x7465646279746573,
    };
    s.v3 = s.v3 ^ m0;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ m0;
    s.v3 = s.v3 ^ m1;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ m1;
    let len_byte: u64 = 16 << 56;
    s.v3 = s.v3 ^ len_byte;
    sip_round(&mut s); sip_round(&mut s);
    s.v0 = s.v0 ^ len_byte;
    s.v2 = s.v2 ^ 0xFF;
    sip_round(&mut s); sip_round(&mut s);
    sip_round(&mut s); sip_round(&mut s);
    return s.v0 ^ s.v1 ^ s.v2 ^ s.v3;
}

// ============================================================================
// Cookie Logic (mirrors kernel/net/tcp_syn_cookie.salt)
// ============================================================================

global TEST_K0: u64 = 0xDEADBEEFCAFEBABE;
global TEST_K1: u64 = 0x0123456789ABCDEF;
global TEST_TICK: u64 = 0;

fn generate_cookie(src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16, client_isn: u32) -> u32 {
    let tuple_hi: u64 = ((src_ip as u64) << 32) | (dst_ip as u64);
    let tuple_lo: u64 = ((src_port as u64) << 16) | (dst_port as u64);
    let hash_val = siphash_2_4(TEST_K0, TEST_K1, tuple_hi, tuple_lo);
    let t = TEST_TICK >> 6;
    let mss_idx: u32 = 3;
    let cookie: u32 = ((t as u32 & 31) << 27) | ((mss_idx & 7) << 24) | (((hash_val as u32) + client_isn) & 0x00FFFFFF);
    if cookie == 0 { return 1; }
    return cookie;
}

fn validate_cookie(cookie: u32, src_ip: u32, dst_ip: u32, src_port: u16, dst_port: u16, client_isn: u32) -> bool {
    let hash_cookie = cookie & 0x00FFFFFF;
    let tuple_hi: u64 = ((src_ip as u64) << 32) | (dst_ip as u64);
    let tuple_lo: u64 = ((src_port as u64) << 16) | (dst_port as u64);
    let hash_val = siphash_2_4(TEST_K0, TEST_K1, tuple_hi, tuple_lo);
    let expected_hash = ((hash_val as u32) + client_isn) & 0x00FFFFFF;
    return hash_cookie == expected_hash;
}

// ============================================================================
// Test Helpers
// ============================================================================

fn assert_true(val: bool, test_name: StringView) {
    if val {
        println("PASS: {}", test_name);
    } else {
        println("FAIL: {}", test_name);
    }
}

fn assert_false(val: bool, test_name: StringView) {
    if !val {
        println("PASS: {}", test_name);
    } else {
        println("FAIL: {}", test_name);
    }
}

fn assert_eq_u64(actual: u64, expected: u64, test_name: StringView) {
    if actual == expected {
        println("PASS: {}", test_name);
    } else {
        println("FAIL: {} — expected {}, got {}", test_name, expected, actual);
    }
}

fn assert_ne_u32(a: u32, b: u32, test_name: StringView) {
    if a != b {
        println("PASS: {}", test_name);
    } else {
        println("FAIL: {} — values equal: {}", test_name, a);
    }
}

// ============================================================================
// Test Cases
// ============================================================================

fn test_siphash_deterministic() {
    // Same input → same output
    let h1 = siphash_2_4(TEST_K0, TEST_K1, 0x1234, 0x5678);
    let h2 = siphash_2_4(TEST_K0, TEST_K1, 0x1234, 0x5678);
    assert_eq_u64(h1, h2, "siphash_deterministic");
}

fn test_siphash_different_keys() {
    let h1 = siphash_2_4(0, 0, 0x1234, 0x5678);
    let h2 = siphash_2_4(1, 0, 0x1234, 0x5678);
    assert_true(h1 != h2, "siphash_different_keys");
}

fn test_siphash_different_messages() {
    let h1 = siphash_2_4(TEST_K0, TEST_K1, 0x1111, 0x2222);
    let h2 = siphash_2_4(TEST_K0, TEST_K1, 0x3333, 0x4444);
    assert_true(h1 != h2, "siphash_different_messages");
}

fn test_cookie_round_trip() {
    let cookie = generate_cookie(
        0xC0A80001, 0xC0A80002,  // 192.168.0.1 → 192.168.0.2
        12345 as u16, 80 as u16,
        0xABCD1234
    );
    let valid = validate_cookie(cookie,
        0xC0A80001, 0xC0A80002,
        12345 as u16, 80 as u16,
        0xABCD1234
    );
    assert_true(valid, "cookie_round_trip");
}

fn test_cookie_validation_fails_on_tamper() {
    let cookie = generate_cookie(
        0xC0A80001, 0xC0A80002,
        12345 as u16, 80 as u16,
        0xABCD1234
    );
    // Tamper: change source IP
    let valid = validate_cookie(cookie,
        0xC0A80099, 0xC0A80002,
        12345 as u16, 80 as u16,
        0xABCD1234
    );
    assert_false(valid, "cookie_validation_fails_on_tamper");
}

fn test_cookie_non_zero() {
    let mut all_nonzero = true;
    let mut i: u32 = 0;
    while i < 1000 {
        let cookie = generate_cookie(
            0xC0A80001 + i, 0xC0A80002,
            (12345 + (i as u16)) as u16, 80 as u16,
            i
        );
        if cookie == 0 {
            all_nonzero = false;
        }
        i = i + 1;
    }
    assert_true(all_nonzero, "cookie_non_zero_1000");
}

fn test_different_tuples_different_cookies() {
    let c1 = generate_cookie(0xC0A80001, 0xC0A80002, 80 as u16, 80 as u16, 1000);
    let c2 = generate_cookie(0xC0A80001, 0xC0A80003, 80 as u16, 80 as u16, 1000);
    assert_ne_u32(c1, c2, "different_tuples_different_cookies");
}

fn test_mss_encoding() {
    let cookie = generate_cookie(
        0x0A000001, 0x0A000002,
        443 as u16, 8080 as u16,
        0x12345678
    );
    // Extract MSS index (bits [26:24])
    let mss_idx = (cookie >> 24) & 7;
    // We hardcoded MSS_DEFAULT = 3 (1460 bytes)
    assert_true(mss_idx == 3, "mss_encoding_default_3");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> i32 {
    println("=== SYN Cookie + SipHash Tests ===");

    test_siphash_deterministic();
    test_siphash_different_keys();
    test_siphash_different_messages();
    test_cookie_round_trip();
    test_cookie_validation_fails_on_tamper();
    test_cookie_non_zero();
    test_different_tuples_different_cookies();
    test_mss_encoding();

    println("=== All SYN cookie tests complete ===");
    return 0;
}
