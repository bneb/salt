// =============================================================================
// tests/chaos/reclamation_storm.salt
// Chaos Monkey — KeuOS Reclamation Stress Test (Directive 4.1)
// =============================================================================
//
// This script spawns "Ephemeral Actors" — processes that immediately:
//   1. Map a large VMO (64MB) — testing page table teardown speed
//   2. Register an SPSC ring     — testing descriptor cleanup
//   3. Terminate immediately      — triggering keuos_reclaim
//
// Target: 1,000 crashes/sec for 60 seconds = 60,000 teardowns.
//
// v1.0.0 KPI Gates:
//   - Reclamation P99 < 1ms
//   - Zero page leaks after 60,000 teardowns
//   - TLB shootdown latency: async, non-blocking
//   - L3 cache misses in PMM < 5% of total accesses
//
// "If the kernel cannot reclaim physical pages, VMOs, and SPSC rings
//  in under 1ms, the system will experience kernel bloat and eventually
//  hang during the 1,000-crash-per-second storm."
// =============================================================================

package tests.chaos.reclamation_storm

import kernel.core.keuos_reclaim
import kernel.core.process
import kernel.core.pmm
import kernel.drivers.serial

// =============================================================================
// Configuration
// =============================================================================

pub const TARGET_CRASH_RATE: u64 = 1000;          // per second
pub const MEMORY_PER_PROC: u64 = 1024 * 1024 * 64; // 64MB VMO per crash
pub const TEST_DURATION_SECS: u64 = 60;
pub const BATCH_SIZE: u64 = 10;                    // 10 every 10ms = 1000/sec
pub const BATCH_INTERVAL_MS: u64 = 10;

// =============================================================================
// Reclamation Histogram — P99 Monitoring
// =============================================================================

pub struct ReclaimHistogram {
    pub count: u64,
    pub total_us: u64,
    pub max_us: u64,
    pub over_1ms_count: u64,     // KPI violations
    pub total_pages_freed: u64,
}

// =============================================================================
// run_chaos_monkey — Entry Point
// =============================================================================

pub fn run_chaos_monkey() {
    serial.print("[chaos] Starting Chaos Monkey: ");
    serial.print_u64(TARGET_CRASH_RATE);
    serial.print(" crashes/sec for ");
    serial.print_u64(TEST_DURATION_SECS);
    serial.print("s\n");

    let histogram = ReclaimHistogram {
        count: 0,
        total_us: 0,
        max_us: 0,
        over_1ms_count: 0,
        total_pages_freed: 0,
    };

    // Record initial free memory for leak detection
    let initial_free_pages = pmm.free_count();

    let batch: u64 = 0;
    let total_batches = (TARGET_CRASH_RATE / BATCH_SIZE) * TEST_DURATION_SECS;

    while batch < total_batches {
        // Spawn and kill a batch of ephemeral actors
        let i: u64 = 0;
        while i < BATCH_SIZE {
            let result = spawn_and_kill_actor();
            histogram.count = histogram.count + 1;
            histogram.total_pages_freed = histogram.total_pages_freed + result.pages_freed;
            histogram.total_us = histogram.total_us + result.elapsed_us;

            if result.elapsed_us > histogram.max_us {
                histogram.max_us = result.elapsed_us;
            }
            if result.kpi_violated != 0 {
                histogram.over_1ms_count = histogram.over_1ms_count + 1;
            }

            i = i + 1;
        }

        // Leak detection: free pages should not decrease
        let current_free = pmm.free_count();
        if current_free < initial_free_pages - 100 {
            serial.print("[chaos] RECLAMATION LEAK: Memory exhausted during storm. ");
            serial.print("Free pages: ");
            serial.print_u64(current_free);
            serial.print(" (initial: ");
            serial.print_u64(initial_free_pages);
            serial.print(")\n");
            return;
        }

        batch = batch + 1;
    }

    // === Report ===
    serial.print("\n[chaos] ===== Chaos Monkey Report =====\n");
    serial.print("[chaos] Total teardowns: ");
    serial.print_u64(histogram.count);
    serial.print("\n[chaos] Total pages freed: ");
    serial.print_u64(histogram.total_pages_freed);
    serial.print("\n[chaos] Max reclamation: ");
    serial.print_u64(histogram.max_us);
    serial.print("us\n[chaos] KPI violations (>1ms): ");
    serial.print_u64(histogram.over_1ms_count);

    let final_free = pmm.free_count();
    serial.print("\n[chaos] Page leak: ");
    if final_free >= initial_free_pages {
        serial.print("ZERO (PASS)\n");
    } else {
        serial.print_u64(initial_free_pages - final_free);
        serial.print(" pages LEAKED (FAIL)\n");
    }

    serial.print("[chaos] ===== End Report =====\n");
}

// =============================================================================
// spawn_and_kill_actor — Create and instantly destroy an ephemeral process
// =============================================================================

fn spawn_and_kill_actor() -> keuos_reclaim.ReclaimResult {
    // In a full implementation, this would:
    //   1. proc.spawn_ephemeral()
    //   2. proc.map_vmo(MEMORY_PER_PROC)
    //   3. proc.register_net_ring(cpu_id: 0)
    //   4. proc.terminate_with_prejudice()
    //
    // For the current kernel, we simulate by:
    //   1. Finding a free process slot
    //   2. Minimally initializing it (allocating a kernel stack + brk region)
    //   3. Immediately calling keuos_reclaim

    // Find a free slot (state == PROC_UNUSED)
    let slot: u64 = 1;  // Start from 1 (slot 0 is the idle task)
    while slot < 16 {
        if process.PROC_TABLE[slot].state == 0 {
            // Initialize minimal process state
            process.PROC_TABLE[slot].pid = slot;
            process.PROC_TABLE[slot].state = process.PROC_RUNNING;
            let kstack = process.alloc_kernel_stack();
            process.PROC_TABLE[slot].kernel_stack_base = kstack;
            process.PROC_TABLE[slot].kernel_stack_top = kstack + process.KSTACK_SIZE;

            // Immediately reclaim — this is the "kill"
            let result = keuos_reclaim.keuos_reclaim(slot);
            return result;
        }
        slot = slot + 1;
    }

    // All slots full — return zero result
    return keuos_reclaim.ReclaimResult {
        pages_freed: 0,
        rings_flushed: 0,
        elapsed_us: 0,
        kpi_violated: 0,
    };
}

pub fn main() {}
