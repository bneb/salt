
package main

extern fn alloc(bytes: u64) -> u64;
extern fn salt_matmul(lhs: u64, rhs: u64, res: u64, m: i64, k: i64, n: i64);

// Write a f32 at offset idx into buffer at base_ptr (u64)
fn write_f32(base_ptr: u64, idx: u64, val: f32) {
    let ptr = reinterpret_cast::<&f32>(base_ptr + idx * 4);
    *ptr = val;
}

// Read a f32 at offset idx from buffer at base_ptr (u64) 
fn read_f32(base_ptr: u64, idx: u64) -> f32 {
    let ptr = reinterpret_cast::<&f32>(base_ptr + idx * 4);
    return *ptr;
}

@no_mangle
fn main_salt() -> i32 {
    println("Starting V5.1 KeuOS FFI MatMul Test...");
    
    // Allocate raw buffers (4x4 = 16 floats = 64 bytes each)
    let i_ptr = alloc(64);
    let a_ptr = alloc(64);
    let b_ptr = alloc(64);
    
    // Initialize I as identity (row-major: [row * 4 + col])
    for row in 0..4 {
        for col in 0..4 {
            let idx = (row * 4 + col) as u64;
            if row == col {
                write_f32(i_ptr, idx, 1.0);
            } else {
                write_f32(i_ptr, idx, 0.0);
            }
        }
    }
    
    // Initialize A as all 2.0
    for i in 0..16 {
        write_f32(a_ptr, i as u64, 2.0);
    }
    
    // Call salt_matmul: B = I * A (4x4 * 4x4 -> 4x4)
    salt_matmul(i_ptr, a_ptr, b_ptr, 4, 4, 4);
    
    // Verify B is all 2.0 (since I is identity)
    println("Verifying B = I * A ...");
    let mut err = 0;
    for i in 0..16 {
        let val = read_f32(b_ptr, i as u64);
        if val != 2.0 {
            print(f"Error at index {i as i64}: ");
            println(f"Expected 2.0, got {val}");
            err = 1;
        }
    }
    
    if err == 0 {
        println("B = I * A PASSED!");
    } else {
        println("B = I * A FAILED.");
    }
    
    return 0;
}
