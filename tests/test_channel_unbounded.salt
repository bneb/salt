package main
import std.channel.channel.UnboundedChannel
import std.core.option.Option
extern fn exit(code: i32);
fn assert_true(cond: bool, id: i32) { if !cond { println(f"FAIL test {id}"); exit(id); } }
fn main() -> i32 {
    println("=== Unbounded Channel Tests ===");
    let mut ch = UnboundedChannel::new();
    assert_true(ch.len() == 0, 1); assert_true(ch.is_empty(), 1);
    println("  [PASS] UnboundedChannel::new()");
    let mut i: i64 = 0; while i < 100 { let _ = ch.send(i); i += 1; }
    assert_true(ch.len() == 100, 2);
    println("  [PASS] send 100 values");
    let v1 = ch.try_recv(); assert_true(v1.is_ok(), 3); assert_true(v1.unwrap() == 0, 3);
    let v2 = ch.try_recv(); assert_true(v2.unwrap() == 1, 3);
    println("  [PASS] FIFO order preserved");
    i = 2; while i < 100 { let v = ch.try_recv(); assert_true(v.is_ok(), 4); assert_true(v.unwrap() == i, 4); i += 1; }
    assert_true(ch.is_empty(), 4);
    println("  [PASS] drain all 100 values");
    assert_true(ch.try_recv().is_err(), 5);
    println("  [PASS] try_recv on empty returns Err");
    i = 0; while i < 2000 { let _ = ch.send(i * 3); i += 1; }
    assert_true(ch.len() == 2000, 6);
    assert_true(ch.try_recv().unwrap() == 0, 6); assert_true(ch.try_recv().unwrap() == 3, 6);
    println("  [PASS] 2000 values, grows as needed");
    while !ch.is_empty() { let _ = ch.try_recv(); }
    let _ = ch.send(10); let _ = ch.send(20);
    assert_true(ch.try_recv().unwrap() == 10, 7);
    let _ = ch.send(30);
    assert_true(ch.try_recv().unwrap() == 20, 7);
    assert_true(ch.try_recv().unwrap() == 30, 7);
    assert_true(ch.is_empty(), 7);
    println("  [PASS] interleaved send/recv");
    println("\n=== All unbounded channel tests passed ==="); return 0;
}
