package main

import std.core.iter.Range
import std.core.option.Option

fn main() -> i32 {
    // Test 1: Basic Range iteration (0..5)
    let mut sum: i64 = 0;
    let iter = Range::new(0, 5);
    for x in iter {
        sum = sum + x;
    }
    // Expected: 0+1+2+3+4 = 10
    if sum != 10 {
        println("FAIL: Expected sum=10");
        return 1;
    }

    // Test 2: Range with non-zero start (3..7)
    let mut sum2: i64 = 0;
    let iter2 = Range::new(3, 7);
    for x in iter2 {
        sum2 = sum2 + x;
    }
    // Expected: 3+4+5+6 = 18
    if sum2 != 18 {
        println("FAIL: Expected sum2=18");
        return 1;
    }

    // Test 3: Empty range (5..5)
    let mut count: i64 = 0;
    let iter3 = Range::new(5, 5);
    for x in iter3 {
        count = count + 1;
    }
    if count != 0 {
        println("FAIL: Expected count=0 for empty range");
        return 1;
    }

    println("PASS: Iterator protocol works!");
    return 0;
}
