import std.collections.hash_map.HashMap
fn assert_eq(a: i64, e: i64) -> bool { return a == e; }
fn main() -> i32 {
    let mut p: i64 = 0; let mut f: i64 = 0;
    println("=== HashMap<i64, i64> Tests ===");
    println("--- Section 1: Basic insert + get ---");
    let mut m1 = HashMap<i64, i64>::with_capacity(16);
    m1.insert(42, 100); let v1 = m1.get_unchecked(&42);
    print("insert(42,100) then get_unchecked == 100");
    if assert_eq(v1, 100) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m1.insert(7, 200);
    print("insert(7,200) then get_unchecked == 200");
    if assert_eq(m1.get_unchecked(&7), 200) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    print("get(999) missing == None");
    if m1.get(&999).is_none() { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m1.drop();
    println("--- Section 2: Overwrite ---");
    let mut m2 = HashMap<i64, i64>::with_capacity(16);
    m2.insert(10, 111); m2.insert(10, 222);
    if assert_eq(m2.get_unchecked(&10), 222) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if assert_eq(m2.len(), 1) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m2.drop();
    println("--- Section 3: Remove ---");
    let mut m3 = HashMap<i64, i64>::with_capacity(16);
    m3.insert(1, 10); m3.insert(2, 20); m3.insert(3, 30);
    if assert_eq(m3.len(), 3) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if m3.remove(&2) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if m3.get(&2).is_none() { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if assert_eq(m3.len(), 2) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if !m3.remove(&999) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if assert_eq(m3.get_unchecked(&1), 10) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    if assert_eq(m3.get_unchecked(&3), 30) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m3.drop();
    println("--- Section 4: Growth ---");
    let mut m4 = HashMap<i64, i64>::with_capacity(8);
    for i in 0..20 { m4.insert(i, i * 100); }
    if assert_eq(m4.len(), 20) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    let mut ok = true;
    for j in 0..20 { if m4.get_unchecked(&j) != j * 100 { ok = false; } }
    if ok { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m4.drop();
    println("--- Section 5: Tombstone reuse ---");
    let mut m5 = HashMap<i64, i64>::with_capacity(16);
    m5.insert(50, 500); m5.remove(&50);
    if m5.get(&50).is_none() { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m5.insert(50, 999);
    if assert_eq(m5.get_unchecked(&50), 999) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m5.drop();
    println("--- Section 6: Empty map ---");
    let m6 = HashMap<i64, i64>::new();
    if assert_eq(m6.len(), 0) && m6.is_empty() && m6.get(&1).is_none() { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    println("--- Section 7: Scale test ---");
    let mut m7 = HashMap<i64, i64>::with_capacity(16);
    for k in 0..1000 { m7.insert(k, k * 7); }
    if assert_eq(m7.len(), 1000) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    let mut cs: i64 = 0;
    for k in 0..1000 { cs += m7.get_unchecked(&k); }
    if assert_eq(cs, 3496500) { println("  ... PASS"); p += 1; } else { println("  ... FAIL"); f += 1; }
    m7.drop();
    println("=== Summary ===");
    if f == 0 { println("ALL TESTS PASSED"); } else { println("SOME TESTS FAILED"); }
    return f as i32;
}
