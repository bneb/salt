package std::random

struct Rng {
    state0: u64,
    state1: u64,
}

impl Rng {
    static fn new(seed: u64) -> Rng {
        return Rng { state0: seed, state1: seed ^ 0xdeadbeefcafebabe };
    }
}

fn next_f32(rng: &mut Rng) -> f32 {
    let mut s1 = rng.state0;
    let s0 = rng.state1;
    rng.state0 = s0;
    s1 = s1 ^ (s1 << 23);
    rng.state1 = s1 ^ s0 ^ (s1 >> 18) ^ (s0 >> 5);
    let res = rng.state1 + s0;
    return (res as f32) / 1.8446744e19; // Full resolution
}
