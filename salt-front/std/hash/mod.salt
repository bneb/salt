// =============================================================================
// String Hash Implementation
// =============================================================================

import std.string.String
import std.core.ptr.Ptr

impl Hash for String {
    @inline
    fn hash(&self) -> u64 {
        return hash_bytes(self.as_ptr(), self.len());
    }
}

