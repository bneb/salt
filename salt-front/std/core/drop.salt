// std/core/drop.salt — RAII Cleanup Trait
// When a variable goes out of scope, its drop() method is called automatically.
// Z3 loves this: resource leak becomes a trivial local property.

package std.core.drop

/// The Drop trait for RAII cleanup.
/// Implement this on types that own resources (files, memory, sockets).
/// The compiler will insert drop() calls at every scope exit.
trait Drop {
    fn drop(&mut self);
}
