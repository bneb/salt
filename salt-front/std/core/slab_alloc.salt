// Slab cache for a specific size class
struct SlabCache<const SIZE: i64> {
    data: [u8; 1024],
    next_free: i64,
}

impl<const SIZE: i64> SlabCache<SIZE> {
    pub fn new() -> SlabCache<SIZE> {
        return SlabCache {
            data: zeroed::<[u8; 1024]>(),
            next_free: 0
        };
    }

    pub fn allocate(&mut self) -> Result<Ptr<u8>> {
        let slots_per_cache = 1024 / SIZE;
        if (*self).next_free >= slots_per_cache {
            return Result::<Ptr<u8>>::Err(Status::resource_exhausted("slab cache full"));
        }
        
        let offset = (*self).next_free * SIZE;
        (*self).next_free += 1;
        
        let ptr = &(*self).data[offset as i32];
        return Result::<Ptr<u8>>::Ok(Ptr::<u8>::from_ref(ptr, SIZE));
    }

    pub fn free(&mut self, _ptr: Ptr<u8>) {
        // Simple bump allocator - no actual freeing in v1
        // Future: maintain free list for O(1) reclamation
    }
}

// Bump allocator
pub struct BumpAlloc {
    heap: [u8; 134217728],  // 128MB heap for larger allocations (supports 100x 1MB sieve)
    offset: i64,
}

impl BumpAlloc {
    pub fn new() -> BumpAlloc {
        return BumpAlloc {
            heap: zeroed::<[u8; 134217728]>(),
            offset: 0
        };
    }

    pub fn alloc(&mut self, layout: Layout) -> Result<Ptr<u8>> {
        let aligned_offset = (self.offset + layout.align - 1) & !(layout.align - 1);
        let new_offset = aligned_offset + layout.size;
        
        if new_offset > 134217728 {
            return Result::<Ptr<u8>>::Err(Status::resource_exhausted("bump allocator full"));
        }
        
        let ptr = &(*self).heap[aligned_offset as i32];
        (*self).offset = new_offset;
        
        return Result::<Ptr<u8>>::Ok(Ptr::<u8>::from_ref(ptr, layout.size));
    }
}

// Global slab allocator
pub struct GlobalSlabAlloc {
    cache_64: SlabCache<64>,
    cache_512: SlabCache<512>,
    cache_4096: SlabCache<4096>,
    fallback: BumpAlloc,
}

impl GlobalSlabAlloc {
    pub fn new() -> GlobalSlabAlloc {
        return GlobalSlabAlloc {
            cache_64: SlabCache::<64>::new(),
            cache_512: SlabCache::<512>::new(),
            cache_4096: SlabCache::<4096>::new(),
            fallback: BumpAlloc::new()
        };
    }
    
    fn alloc(&mut self, layout: Layout) -> Result<Ptr<u8>> {
        if layout.size <= 64 {
            return self.cache_64.allocate();
        } else if layout.size <= 512 {
            return self.cache_512.allocate();
        } else if layout.size <= 4096 {
            return self.cache_4096.allocate();
        }
        return (*self).fallback.alloc(layout);
    }

    fn dealloc(&mut self, ptr: Ptr<u8>, layout: Layout) {
        if layout.size <= 64 {
            (*self).cache_64.free(ptr);
        } else if layout.size <= 512 {
            (*self).cache_512.free(ptr);
        } else if layout.size <= 4096 {
            (*self).cache_4096.free(ptr);
        } else {
            // Large allocations: reset bump allocator offset for reuse
            // This is a simple strategy that works when allocations are LIFO
            // (which they are for the sieve benchmark - one Vec per function call)
            (*self).fallback.offset = (*self).fallback.offset - layout.size;
            if (*self).fallback.offset < 0 {
                (*self).fallback.offset = 0;
            }
        }
    }
}

// Global instance
global GLOBAL_ALLOC: GlobalSlabAlloc = GlobalSlabAlloc::new();

// Public wrappers used by Vec
pub fn alloc(layout: Layout) -> Result<Ptr<u8>> {
    return GLOBAL_ALLOC.alloc(layout);
}

pub fn dealloc(ptr: Ptr<u8>, layout: Layout) {
    GLOBAL_ALLOC.dealloc(ptr, layout);
}
