package std.test

// Salt Standard Test Library
// Used by @test functions for compile-time and run-time testing.

public fn assert(condition: bool) {
    if !condition {
        // Panic with a standard message. 
        // In the future, we might support custom messages or formatted strings.
        panic("Assertion failed")
    }
}

public fn assert_eq(a: u64, b: u64) {
    if a != b {
        panic("Assertion failed: left != right")
    }
}
