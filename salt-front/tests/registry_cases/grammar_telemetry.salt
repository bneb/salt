package kernel.test

import kernel.drivers.serial as uart
import kernel.core.io

const VGA_ADDR: u64 = 0xB8000;

fn test_regions() {
    // 1. region("name") syntax with cross-module io.outb call
    region("init") {
        io.outb(0x3F8, 0x42)
    }
}

pub fn main() -> i32 {
    uart.init();
    test_regions();
    return 0;
}
