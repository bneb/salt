
// Statement Coverage Torture

// 1. Nested Control Flow Labels
fn loop_torture() -> i32 {
    let mut sum = 0;
    
    // Outer Loop: Label 0
    let mut i = 0;
    while i < 10 {
        i = i + 1;
        
        // Inner Loop: Label 1
        let mut j = 0;
        while j < 5 {
             j = j + 1;
             
             if i == 5 {
                 // Should jump to Label 0 continue (cond check)
                 // This tests 'break/continue' stack depth
                 continue; // Continue inner or outer? Continue applies to inner-most loop. 
                 // To continue outer, we don't have labeled break syntax in Salt yet?
                 // If not, we just test local continue.
             }
             
             if j == 3 {
                 sum = sum + 100;
                 continue;
             }
             
             sum = sum + 1;
        }
        
        if i > 8 {
            break; // Break outer
        }
    }
    return sum;
}

// 2. Return Promotion
fn return_prom() -> i64 {
    // Return i32, expect i64
    return 42; 
}

fn return_prom_float() -> f64 {
    // Return f32, expect f64
    return 3.14;
}

struct Point {
    x: i32,
    y: i32
}

struct Flag {
    active: bool
}

// 3. Pattern Matching Torture
fn pat_torture() -> i32 {
    let p = Point { x: 10, y: 20 };
    
    // Destructure Struct
    let Point { x, y } = p;
    
    // Destructure Tuple
    let t = (100, 200);
    let (a, b) = t;
    
    // Boolean Truncation in Pattern
    let f = Flag { active: true };
    let Flag { active } = f;
    
    if active {
        return x + y + a + b;
    }
    return 0;
}

fn main() -> i32 {
    loop_torture();
    return_prom();
    return_prom_float();
    pat_torture();
    return 0;
}
