fn main() -> i32 {
    let mut sum = 0;
    
    // 0..0 range -> Loop latch boundary
    for i in 0..0 {
        sum = sum + i;
    }

    // 10..10 empty range
    for j in 10..10 {
        sum = sum + j;
    }

    // Reverse range? edge case
    for k in 10..5 {
        sum = sum + k;
    }

    return sum;
}
