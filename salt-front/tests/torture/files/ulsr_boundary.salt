fn get_status_ok() -> Status {
    return Status::Ok;
}

fn get_status_found() -> Status {
    return Status::Found;
}

fn get_status_error() -> Status {
    return Status::Error ^ "Generic error";
}

fn main() -> i32 {
    // Boundary checks for ULSR
    // Test various status values and the ? operator
    
    let s_ok = get_status_ok();
    let s_found = get_status_found();
    let s_err = get_status_error();

    // Test ? operator on boundaries
    // These should propagate appropriately
    test_propagation_ok();
    test_propagation_error();

    // Test .is_found() and .is_error() methods
    if s_found.is_found() {
        return 0;
    }
    
    if s_err.is_error() {
        return 1;
    }

    return 0;
}

fn test_propagation_ok() -> Status {
    let x = get_status_ok()?;
    return Status::Ok;
}

fn test_propagation_error() -> Status {
    let x = get_status_error()?;
    return Status::Ok;
}
