fn main() -> i32 {
    // Chaining multiple context strings
    // This exercises the string table and metadata registers
    
    let s = Status::Error;
    // The ^ operator is aliased to context addition
    let s_ctx = s ^ "Reason A" ^ "Reason B" ^ "Reason C";
    
    // Check literal with context
    let s_found = Status::Found ^ "Initial context";
    
    // Check chained context on found status
    let s_chained = s_found ^ "Additional context";

    // Verify usage via method calls
    if s_ctx.is_error() {
        return 1;
    }
    
    if s_chained.is_found() {
        return 0;
    }

    return 2;
}
