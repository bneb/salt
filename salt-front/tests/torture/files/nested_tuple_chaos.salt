fn main() -> i32 {
    // Deeply nested tuple destructuring
    let complex = ((1, 2), (3, (4, 5)));
    
    let ((a, b), (c, (d, e))) = complex;
    
    // Verify values usage
    let sum = a + b + c + d + e;
    
    // Another variant with mixed depth
    let mixed_depth = (1, (2, (3, 4)));
    let (x, (y, (z, w))) = mixed_depth;

    return sum + z;
}
