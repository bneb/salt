// 1. Pathological Cast Chains (5+ consecutive as casts)
fn cast_chain_pathological(v: f64) -> i16 {
    // f64 -> u8 (narrow/sat) -> i32 (widen) -> i16 (narrow) -> u64 (widen) -> i16 (narrow)
    return v as u8 as i32 as i16 as u64 as i16;
}

// 2. Boolean Law Torture (15+ clauses)
fn short_circuit_stress(a: bool, b: bool, c: bool, d: bool) -> bool {
    return (a && b) || (b && c) || (a && c) && (a || b || c || d) && (a && !d) || (d && !a) || (b && !c) || (c && !b);
}

// 3. Exhaustive Early Returns (20+ branches)
fn return_stress(x: i32) -> i64 {
    if x == 0 { return 0; }
    if x == 1 { return 1; }
    if x == 2 { return 2; }
    if x == 3 { return 3; }
    if x == 4 { return 4; }
    if x == 5 { return 5; }
    if x == 6 { return 6; }
    if x == 7 { return 7; }
    if x == 8 { return 8; }
    if x == 9 { return 9; }
    if x == 10 { return 10; }
    if x == 11 { return 11; }
    if x == 12 { return 12; }
    if x == 13 { return 13; }
    if x == 14 { return 14; }
    if x == 15 { return 15; }
    if x == 16 { return 16; }
    if x == 17 { return 17; }
    if x == 18 { return 18; }
    if x == 19 { return 19; }
    if x == 20 { return 20; }
    return x as i64;
}

// 4. Deep Loop Nesting (Stress loop stack)
fn label_hell() {
    let mut i = 0;
    while i < 10 {
        let mut j = 0;
        while j < 10 {
            let mut k = 0;
            while k < 10 {
                if k == 5 { break; }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

// 5. Shift Edge Case Matrix
fn shift_edge_cases(x: u32, s: u32) -> u32 {
    let s0 = x << 0;
    let s32 = x << 32; // Should hit safety branch
    let s64 = x << 64; // Should hit safety branch
    return s0 + s32 + s64;
}

// 6. Block Expression Promotion
fn block_promotion() -> i64 {
    let x: i64 = {
        let y: i32 = 10;
        y // Implicit promotion i32 -> i64
    };
    return x;
}

fn main() -> i32 {
    cast_chain_pathological(3.14);
    short_circuit_stress(true, false, true, false);
    return_stress(20);
    label_hell();
    shift_edge_cases(10, 32);
    block_promotion();
    return 0;
}
