
// Final Z3 Pathology

// 1. Non-Linear Arithmetic
// x * y + z == 42 triggers non-linear solver logic in Z3 if enabled
fn nonlinear_check(x: i32, y: i32) -> i32 {
    let z = 42 - (x * y);
    // This requires x*y <= 42 for z to be positive? Not necessarily.
    // Just simple arithmetic to ensure Z3 sees mul/add.
    if x * y + z == 42 {
        return 1;
    }
    return 0;
}

// 2. Bit-Vector Overflows
fn overflow_check(x: u32) -> bool {
    // If x is MAX_U32, x + 1 wraps to 0.
    // 0 < MAX_U32 is true.
    // So this condition is true ONLY on overflow.
    if x + 1 < x {
        return true;
    }
    return false;
}

// 3. Complex Boolean Logic for Z3
fn boolean_logic(a: bool, b: bool, c: bool) -> bool {
    // (A -> B) <-> (!A || B)
    let implies = !a || b;
    let equiv = implies == (!a || b);
    
    // Z3 should prove this is always true (tautology)
    // If we assert !equiv is UNSAT.
    return equiv;
}

fn main() -> i32 {
    nonlinear_check(6, 7);
    overflow_check(4294967295);
    boolean_logic(true, false, true);
    return 0;
}
