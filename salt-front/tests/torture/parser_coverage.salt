
// Parser Coverage Torture

// 1. Trailing Commas
struct TrailingStruct {
    x: i32,
    y: i32, // Trailing comma
}

enum TrailingEnum {
    A,
    B, // Trailing comma
}

// 2. Empty Blocks and Functions
fn empty_fn() {}

fn nested_empty() {
    if true {}
    while false {}
    {
        // Empty block scope
    }
}

// 3. Complex Types
// Function type in struct
struct Callback {
    cb: fn(i32) -> bool,
}

// Tuple types
type MyTuple = (i32, f64,); // Trailing comma in tuple type?

fn main() -> i32 {
    let t = TrailingStruct { x: 1, y: 2, }; // Trailing comma in init
    
    // Explicit type vs inferred
    // Closure codegen not yet supported; only function pointers are tested here.
    
    nested_empty();
    
    return 0;
}
