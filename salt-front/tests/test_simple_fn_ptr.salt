package tests.test_simple_fn_ptr

fn is_even(x: i64) -> bool {
    return (x % 2) == 0;
}

fn apply<F>(f: F, val: i64) -> bool {
    return f(val);
}

pub fn main() -> i32 {
    // Test: Pass function 'is_even' as a value to 'apply'
    // This triggers emit_path for 'is_even', which must:
    // 1. Materialize it as a function pointer (SSA value)
    // 2. Schedule 'is_even' for code generation (demand-driven fix)
    
    let res = apply(is_even, 4);
    
    if res {
        println("Success: 4 is even");
        return 42;
    }
    
    println("Failure: 4 is not even?");
    return 1;
}
