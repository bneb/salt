// KeuOS Writer Protocol - Test Demonstration
// This file demonstrates the target.f"..." syntax for zero-allocation streaming output

package test.writer_protocol

import std.io.mod.Console
import std.io.writer.Writer
import std.string.String

fn main() -> i64 {
    // Demonstration 1: Direct Console output (no intermediate String)
    let mut console = Console {};
    
    let x = 42;
    let name = "Salt";
    
    // KeuOS Writer Protocol: decomposed directly to write_* calls
    // console.f"Hello from {name}! The answer is {x}.\n";
    
    // This expands to:
    //   console.write_str("Hello from ", 12);
    //   console.write_str(name, strlen(name));  
    //   console.write_str("! The answer is ", 17);
    //   console.write_i32(x);
    //   console.write_str(".\n", 2);
    
    // Demonstration 2: Buffer accumulation (for later use)
    let mut buf = String::with_capacity(128);
    
    let pi = 3.14159;
    let iterations = 1000000i64;
    
    // Format into buffer with precision specifier
    // buf.f"Pi to 2 decimals: {pi:.2f}, iterations: {iterations}\n";
    
    // This expands to:
    //   buf.write_str("Pi to 2 decimals: ", 18);
    //   buf.write_f64_prec(pi, 2);
    //   buf.write_str(", iterations: ", 14);
    //   buf.write_i64(iterations);
    //   buf.write_str("\n", 1);
    
    // Output the buffer
    console.print_str(buf.as_bytes());
    
    return 0;
}

// Expected expansion for console.f"Value: {x}" when compiler is fully connected:
// 
// The preprocessor transforms:
//   console.f"Value: {x}"
// Into:
//   __target_fstring__!(console, "Value: {x}")
// 
// Which codegen expands via native_target_fstring_expand to:
//   {
//       console.write_str("Value: ", 7);
//       console.write_i32(x);
//   }
