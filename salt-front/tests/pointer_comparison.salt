// Regression tests for pointer comparison codegen
// These tests verify that comparing pointers does NOT dereference them

extern fn malloc_shim(size: usize) -> !llvm.ptr;

pub fn main(argc: i32) -> i32 {
    // Test 1: null check with 0 as !llvm.ptr
    let ptr: !llvm.ptr = 0 as !llvm.ptr;
    if ptr == (0 as !llvm.ptr) {
        println("Test 1 PASS: null == null");
    } else {
        println("Test 1 FAIL: null != null");
        return 1;
    }
    
    // Test 2: non-null check  
    let ptr2 = malloc_shim(8);
    if ptr2 != (0 as !llvm.ptr) {
        println("Test 2 PASS: malloc != null");
    } else {
        println("Test 2 FAIL: malloc == null");
        return 2;
    }
    
    // Test 3: comparison of two pointers
    let ptr3 = 0 as !llvm.ptr;
    if ptr == ptr3 {
        println("Test 3 PASS: null == null (vars)");
    } else {
        println("Test 3 FAIL: null != null (vars)");
        return 3;
    }
    
    // Test 4: ptr != ptr should be false for same value
    if ptr != ptr3 {
        println("Test 4 FAIL: null != null should be false");
        return 4;
    } else {
        println("Test 4 PASS: !(null != null)");
    }
    
    // Test 5: loop with null check (the actual failure case)
    let mut arr: [!llvm.ptr; 4] = [0 as !llvm.ptr; 4];
    let mut count = 0;
    let mut i = 0;
    while i < 4 {
        if arr[i] == (0 as !llvm.ptr) {
            count = count + 1;
        }
        i = i + 1;
    }
    if count == 4 {
        println("Test 5 PASS: loop null check works");
    } else {
        println("Test 5 FAIL: loop null check broken");
        return 5;
    }
    
    println("All pointer comparison tests passed!");
    return 0;
}
