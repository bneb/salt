// Regression test for bounded loop termination
// This tests that while loops with modular arithmetic don't infinite loop
// when the search space is fully explored.

pub fn main(argc: i32) -> i32 {
    // Simulate linear probing in a small array
    let mut arr: [i32; 8] = [1, 1, 1, 1, 1, 1, 1, 1]; // All slots "full"
    
    let mut i: usize = 0;
    let mut count: usize = 0;
    
    // This loop should terminate after 8 iterations, not infinite loop
    while count < 8 {
        if arr[i] == 0 {
            // Found empty slot
            count = 8; // Break
        } else {
            i = (i + 1) % 8;
            count = count + 1;
        }
    }
    
    // If we get here, the loop terminated correctly
    println(f"Loop terminated after {count as i64} iterations");
    
    if count == 8 {
        println("PASS: Bounded loop terminated correctly");
        return 0;
    } else {
        println("FAIL: Unexpected termination");
        return 1;
    }
}
