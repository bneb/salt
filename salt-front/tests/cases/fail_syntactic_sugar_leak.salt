
struct Data {
    id: i32
}

fn create_data() -> Owned<Data> {
    return Box::new(Data { id: 1 });
}

fn main() -> i32 {
    let d = create_data();
    // Error: Resource Leak: variable d of type Owned(Struct("Data")) is never consumed
    // This demonstrates Salt's Layer 1 Formal Verification (Linear Type Safety).
    // Even if Z3 doesn't find a memory safety error, the compiler refuses to leak resources.
    return 0;
}
