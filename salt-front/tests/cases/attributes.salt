// Comprehensive Attribute and Annotation Usage
package tests.attributes

@hot
fn hot_arithmetic() -> i32 {
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 100 {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

fn pulsed_function() -> i32 {
    let x: i32 = 42;
    return x * 2;
}

fn main() -> i32 {
    let a = hot_arithmetic();
    let b = pulsed_function();
    return 0;
}
