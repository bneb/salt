// Test: TLS/Crypto module — OpenSSL context lifecycle
// Verifies context creation and basic lifecycle management.
// Note: Actual TLS connections require a running server, so this test
// only validates the Salt → C bridge → OpenSSL context creation path.
//
// OUTPUT: === TLS Tests ===
// OUTPUT: test_client_ctx: PASS
// OUTPUT: test_invalid_server_ctx: PASS
// OUTPUT: ALL TESTS PASSED

import std.crypto.tls.TlsContext

fn main() -> i32 {
    println("=== TLS Tests ===");

    // Test 1: Create a valid client TLS context
    let mut ctx = TlsContext::client();
    if ctx.is_valid() {
        println("test_client_ctx: PASS");
    } else {
        println("test_client_ctx: FAIL");
    }
    ctx.drop();

    // Test 2: Server context with non-existent cert should fail
    let mut ctx2 = TlsContext::server("/nonexistent/cert.pem\0", "/nonexistent/key.pem\0");
    if ctx2.is_valid() {
        println("test_invalid_server_ctx: FAIL");
    } else {
        println("test_invalid_server_ctx: PASS");
    }
    ctx2.drop();

    println("ALL TESTS PASSED");
    return 0;
}
