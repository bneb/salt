fn timeout_logic(a: i32, b: i32, c: i32, d: i32, e: i32, f: i32, g: i32) -> i32
requires { 
    a*a + b*b + c*c + d*d + e*e + f*f + g*g == 1234567 &&
    a*b + c*d + e*f + g == 9999 &&
    a > 0 && b > 0 && c > 0 && d > 0 && e > 0 && f > 0 && g > 0 
}
{
    return a;
}

fn main() -> i32 {
    let _ = timeout_logic(1, 2, 3, 4, 5, 6, 7);
    return 0;
}
