
// Helper to create an Owned value so the compiler sees the type
fn get_owned() -> std::Owned<i32> {
    let x: i64 = 0;
    // Cast integer to Owned pointer to fake it
    return reinterpret_cast<std::Owned<i32>>(x);
}

fn main() -> i32 {
    let a = get_owned();
    
    // First move
    let b = a;
    
    // Deliberate second move/use of 'a'
    // This should fail because 'a' has already been moved to 'b'
    let c = a;
    
    return 0;
}
