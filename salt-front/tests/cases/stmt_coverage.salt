fn test_invariant(i: i32) {
    invariant i > 0;
}

fn test_move(x: i32) {
    // move is a hint in Salt, verifies compilation
    move x;
}

fn test_with_region() {
    with VRAM {
        let x = 10;
        test_invariant(x);
    }
}

// map_window is for kernels, might require specific args
fn test_map_window(addr: u64, size: u64) {
    // map_window(addr, size, REGION)
    map_window(addr, size, VRAM);
}

fn main() -> i32 {
    test_invariant(10);
    test_move(5);
    test_with_region();
    test_map_window(0, 1024);
    return 0;
}
