// Test: Time/Duration module
// Verifies Duration arithmetic and Instant measurements
//
// OUTPUT: === Time/Duration Tests ===
// OUTPUT: Duration::from_secs(2).as_secs() == 2  ... PASS
// OUTPUT: Duration::from_millis(1500).as_millis() == 1500  ... PASS
// OUTPUT: Duration::from_millis(1500).as_secs() == 1  ... PASS
// OUTPUT: Duration::from_nanos(5000).as_micros() == 5  ... PASS
// OUTPUT: Duration::from_secs(0).is_zero()  ... PASS
// OUTPUT: Duration add  ... PASS
// OUTPUT: Duration sub  ... PASS
// OUTPUT: Duration sub saturates at 0  ... PASS
// OUTPUT: Instant::now() returns positive nanos  ... PASS
// OUTPUT: elapsed >= 0  ... PASS
// OUTPUT: ALL TESTS PASSED

import std.time.Duration
import std.time.Instant

fn main() -> i32 {
    let mut passed: i64 = 0;
    let mut failed: i64 = 0;

    println("=== Time/Duration Tests ===");

    // =========================================================================
    // Duration constructors and conversions
    // =========================================================================
    let d1 = Duration::from_secs(2);
    print("Duration::from_secs(2).as_secs() == 2");
    if d1.as_secs() == 2 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let d2 = Duration::from_millis(1500);
    print("Duration::from_millis(1500).as_millis() == 1500");
    if d2.as_millis() == 1500 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    print("Duration::from_millis(1500).as_secs() == 1");
    if d2.as_secs() == 1 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let d3 = Duration::from_nanos(5000);
    print("Duration::from_nanos(5000).as_micros() == 5");
    if d3.as_micros() == 5 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let d_zero = Duration::from_secs(0);
    print("Duration::from_secs(0).is_zero()");
    if d_zero.is_zero() { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // =========================================================================
    // Duration arithmetic
    // =========================================================================
    let a = Duration::from_millis(500);
    let b = Duration::from_millis(300);
    let sum = a.add(&b);
    print("Duration add");
    if sum.as_millis() == 800 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let diff = a.sub(&b);
    print("Duration sub");
    if diff.as_millis() == 200 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let saturated = b.sub(&a);
    print("Duration sub saturates at 0");
    if saturated.is_zero() { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // =========================================================================
    // Instant
    // =========================================================================
    let start = Instant::now();
    print("Instant::now() returns positive nanos");
    if start.nanos > 0 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let elapsed = start.elapsed();
    print("elapsed >= 0");
    if elapsed.as_nanos() >= 0 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // =========================================================================
    // Summary
    // =========================================================================
    if failed == 0 {
        println("ALL TESTS PASSED");
    } else {
        println("SOME TESTS FAILED");
    }

    return failed as i32;
}
