
const TEST_INT: u32 = 42;
const TEST_FLOAT: f64 = 3.14159;
const TEST_BOOL: bool = true;

global counter: u32 = 0;
global threshold: u32 = 100;

// Regression test for struct panic
struct Dummy {
    val: i32
}

fn main() -> i32 {
    let mut x = 0;
    
    // Test const usage (immediate value)
    while x < TEST_INT {
        x = x + 1;
    }
    
    // Test global usage (load)
    let t = threshold;
    if x < t {
        return 1; // Should not happen if x reached 42
    }
    
    // Test bool const
    if TEST_BOOL {
        // Valid path
        return 0;
    }
    
    return 1;
}
