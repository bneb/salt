// Comprehensive Array Operations
package tests.arrays

struct ArrayHolder {
    values: [i32; 4],
    count: i32
}

fn test_basic_arrays() -> i32 {
    let mut arr: [i32; 4] = [1, 2, 3, 4];
    arr[0] = 10;
    let x = arr[1];
    return arr[0] + x;
}

fn test_struct_with_array() -> i32 {
    let holder: ArrayHolder = ArrayHolder { 
        values: [1, 2, 3, 4], 
        count: 4 
    };
    return holder.values[0] + holder.values[3] + holder.count;
}

fn test_mutable_struct_array() -> i32 {
    let mut holder: ArrayHolder = ArrayHolder { 
        values: [0, 0, 0, 0], 
        count: 0 
    };
    holder.values[0] = 10;
    holder.values[1] = 20;
    holder.values[2] = 30;
    holder.values[3] = 40;
    holder.count = 4;
    
    return holder.values[0] + holder.values[1] + holder.count;
}

struct Point3D { coords: [f64; 3] }

fn test_float_array_in_struct() -> i32 {
    let p: Point3D = Point3D { coords: [1.0, 2.0, 3.0] };
    let sum: f64 = p.coords[0] + p.coords[1] + p.coords[2];
    return sum as i32;
}

fn main() -> i32 {
    let r1 = test_basic_arrays();
    let r2 = test_struct_with_array();
    let r3 = test_mutable_struct_array();
    let r4 = test_float_array_in_struct();
    return 0;
}
