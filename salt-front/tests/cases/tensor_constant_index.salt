// Bug 4: Usize literals emit as i64 instead of index
// Constant indices like (0, 0) should work with memref.load outside affine context
package main

fn main() -> i32 {
    let t = Tensor::<f64>(42.0, [4, 4]);
    let val = t[(0, 0)];  // Constant indices should emit as index type
    if val > 41.0 { return 0; }
    return 1;
}
