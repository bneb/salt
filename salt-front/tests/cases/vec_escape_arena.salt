// vec_escape_arena.salt — NEGATIVE TEST
// Expected: Compiler rejects this with arena escape violation.
// An arena-backed Vec CANNOT be returned from the function
// that created the arena, because the arena dies when the function returns.
package main

import std.mem.allocator.ArenaAllocator;
import std.mem.allocator.HeapAllocator;
import std.collections.vec.Vec;
import std.core.arena.Arena;

// This function should be REJECTED by escape analysis.
// The Vec's data lives on a local arena that dies when this function returns.
pub fn create_dangling_vec() -> Vec<i64, ArenaAllocator> {
    let arena = Arena::new(4096);
    let alloc = ArenaAllocator { arena: arena };
    let mut v = Vec::<i64, ArenaAllocator>::new(alloc, 4);
    v.push(1);
    v.push(2);
    v.push(3);
    return v;    // Arena escape violation: 'v' (depth 2) cannot be returned
}

pub fn main() -> i32 {
    let result = create_dangling_vec();
    return 0;
}
