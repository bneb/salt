// Bug 3: Mutable Tensors stored as alloca instead of SSA
// Tensors are memrefs which should stay SSA even when mutable
package main

fn main() -> i32 {
    let mut t = Tensor::<f64>(0.0, [8, 8]);  // mut Tensor should still be SSA
    t[(0, 0)] = 5.0;
    t[(0, 0)] += 3.0;
    if t[(0, 0)] > 7.0 { return 0; }
    return 1;
}
