
struct BoolStruct {
    a: bool,
    b: i32,
    c: bool
}

struct BoolArrayContainer {
    flags: [bool; 4],
    data: i32
}

fn test_struct_bool() -> bool {
    let mut s = BoolStruct { a: true, b: 42, c: false };
    
    // Test Loading
    if !s.a {
        return false;
    }
    
    // Test Storing
    s.c = true;
    if !s.c {
        return false;
    }
    
    // Test Reference Access
    let ref_s = &mut s;
    if !ref_s.a {
        return false;
    }
    ref_s.a = false;
    if ref_s.a {
        return false;
    }
    
    return true;
}

fn test_array_bool() -> bool {
    let mut arr: [bool; 4];
    arr[0] = true;
    arr[1] = false;
    arr[2] = true;
    arr[3] = false;
    
    if !arr[0] { return false; }
    if arr[1] { return false; }
    
    // Test Pointer Arithmetic / Indexing
    let ptr = &arr as !llvm.ptr as &mut bool;
    
    // Note: If i1/i8 size is wrong, this offset will be wrong
    // ptr[2] should be byte offset 2
    if !ptr[2] { return false; }
    
    return true;
}

fn test_compound_assign() -> bool {
    let mut x: bool = false;
    x |= true; // Should use i8 storage load -> i1 calc -> i8 store
    
    if !x { return false; }
    
    x &= false;
    if x { return false; }
    
    return true;
}

fn main() -> i32 {
    if !test_struct_bool() { return 1; }
    if !test_array_bool() { return 2; }
    if !test_compound_assign() { return 3; }
    
    return 0;
}
