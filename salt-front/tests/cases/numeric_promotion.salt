fn takes_i32(x: i32) {}
fn takes_u32(x: u32) {}
fn takes_i64(x: i64) {}
fn takes_f64(x: f64) {}
fn takes_f32(x: f32) {}
fn takes_u8(x: u8) {}

fn main() {
    let i: i32 = 10;
    
    // I32 -> I64 / U64 / Usize
    takes_i64(i);
    
    // I32 -> U32 (bitcast/same width) - may trigger signedness fix
    takes_u32(i);

    // I32 -> U8 (trunc)
    takes_u8(i as u8);

    // I32 -> F64 (sitofp) - Needs explicit cast now
    takes_f64(i as f64);
    
    // Explicit types
    let l_val: i64 = 1000;
    // I64 -> I32 (trunc)
    takes_i32(l_val as i32);
    // I64 -> U8 (trunc)
    takes_u8(l_val as u8);
    
    let f: f32 = 1.5;
    // F32 -> F64 (fpext)
    takes_f64(f);
    
    let d: f64 = 2.5;
    takes_f32(d as f32);
}
