// Full MatMul pattern: read A, read B, compute, write res
// Tests: affine.for, affine.load, affine.store, compound assignment
package main

fn main() -> i32 {
    let a = Tensor::<f64>(1.0, [32, 32]);
    let b = Tensor::<f64>(2.0, [32, 32]);
    let mut res = Tensor::<f64>(0.0, [32, 32]);
    
    for i in 0..32 {
        for j in 0..32 {
            for k in 0..32 {
                res[(i, j)] += a[(i, k)] * b[(k, j)];
            }
        }
    }
    
    // 32 * 1.0 * 2.0 = 64.0
    if res[(0, 0)] > 63.0 && res[(0, 0)] < 65.0 { return 0; }
    return 1;
}
