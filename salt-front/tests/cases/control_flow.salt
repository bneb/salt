// Comprehensive Control Flow Operations
package tests.control_flow

fn test_if_else(x: i32) -> i32 {
    let mut i = 0;
    let mut sum = 0;
    if x > 10 {
        while i < x {
            sum = sum + i;
            i = i + 1;
        }
    } else {
        sum = -1;
    }
    return sum;
}

fn test_for_loop() -> i32 {
    let mut sum = 0;
    for i in 0..10 {
        sum += i;
    }
    return sum;
}

fn test_repeat_loop() -> i32 {
    let mut sum = 0;
    let mut i = 0;
    while i < 10 {
        sum += i;
        i += 1;
    }
    return sum;
}

fn test_nested_loops() -> i32 {
    let mut sum = 0;
    for i in 0..5 {
        for j in 0..5 {
            sum += i * j;
        }
    }
    return sum;
}

fn main() -> i32 {
    let r1 = test_if_else(15);
    let r2 = test_for_loop();
    let r3 = test_repeat_loop();
    let r4 = test_nested_loops();
    return 0;
}
