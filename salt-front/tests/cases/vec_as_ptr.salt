// Test: Vec<T, A>::as_ptr() should produce correct multi-generic type aliases
// This is a minimal repro for the codegen bug where .as_ptr() on Vec<f32, ArenaAllocator>
// emits !struct_std__collections__vec__Vec_f32 instead of
// !struct_std__collections__vec__Vec_f32_std__mem__allocator__ArenaAllocator

package main

import std.core.arena.Arena;
import std.mem.allocator.ArenaAllocator;
import std.collections.vec.Vec;

pub fn main_salt() -> i32 {
    let arena = Arena::new(4096);
    let alloc = ArenaAllocator { arena: arena };

    let mut v = Vec::<i64, ArenaAllocator>::new(alloc, 4);

    // This should work — get raw pointer via .as_ptr()
    let ptr = v.as_ptr();
    ptr[0] = 42;

    println(f"value: {ptr[0]}");
    println("PASS: as_ptr works on Vec<T, A>");

    v.free();
    return 0;
}
