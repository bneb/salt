package main

// Test 2: Box::new() allocates and initializes
// Expected: prints "42" (the value stored in the Box)

import std.core.ptr.Ptr
import std.core.boxed.Box

struct Simple { val: i32 }

fn main() -> i32 {
    let b = Box::<Simple>::new(Simple { val: 42 });
    let s = b.read();
    println(f"val: {s.val as i64}");
    b.drop();
    return 0;
}
