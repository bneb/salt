// Codegen coverage test cases
// Designed to hit uncovered codegen paths

fn test_all_primitives() -> i32 {
    let a: i8 = 1 as i8;
    let b: u8 = 2 as u8;
    let c: i32 = 3;
    let d: u32 = 4 as u32;
    let e: i64 = 5 as i64;
    let f: u64 = 6 as u64;
    let g: f32 = 7.0 as f32;
    let h: f64 = 8.0;
    let i: bool = true;
    return c;
}

fn test_arithmetic_all_types() -> i32 {
    let a: i32 = 10 + 5;
    let b: i32 = 10 - 5;
    let c: i32 = 10 * 5;
    let d: i32 = 10 / 5;
    let e: i32 = 10 % 3;
    
    let f: u32 = 10 as u32 / 3 as u32;
    let g: u32 = 10 as u32 % 3 as u32;
    
    let h: f64 = 10.0 + 5.0;
    let i: f64 = 10.0 - 5.0;
    let j: f64 = 10.0 * 5.0;
    let k: f64 = 10.0 / 5.0;
    
    return a + b + c + d + e;
}

fn test_comparisons() -> i32 {
    let a: bool = 5 < 10;
    let b: bool = 5 <= 10;
    let c: bool = 5 > 10;
    let d: bool = 5 >= 10;
    let e: bool = 5 == 10;
    let f: bool = 5 != 10;
    
    let g: bool = 5.0 < 10.0;
    let h: bool = 5.0 <= 10.0;
    let i: bool = 5.0 > 10.0;
    let j: bool = 5.0 >= 10.0;
    
    return 0;
}

fn test_bitwise_ops() -> i32 {
    let a: i32 = 0xFF & 0x0F;
    let b: i32 = 0xFF | 0x0F;
    let c: i32 = 0xFF ^ 0x0F;
    let d: i32 = 1 << 4;
    let e: i32 = 16 >> 2;
    return a + b + c + d + e;
}

fn test_unary_ops() -> i32 {
    let a: i32 = -5;
    let b: i32 = !0xFF;
    let c: bool = !true;
    return a + b;
}

fn test_control_flow() -> i32 {
    let mut x: i32 = 0;
    
    if true {
        x = 1;
    } else {
        x = 2;
    }
    
    if false {
        x = 3;
    }
    
    let mut i: i32 = 0;
    while i < 5 {
        x = x + 1;
        i = i + 1;
    }
    
    let mut j: i32 = 0;
    for k in 0..10 {
        j = j + 1;
    }
    
    return x + j;
}

fn test_array_ops() -> i32 {
    let arr: [i32; 5] = [1, 2, 3, 4, 5];
    let x: i32 = arr[0];
    let y: i32 = arr[4];
    
    let mut arr2: [i32; 3] = [0, 0, 0];
    arr2[0] = 10;
    arr2[1] = 20;
    arr2[2] = 30;
    
    return x + y + arr2[0];
}

fn test_tuple_ops() -> i32 {
    let t: (i32, i64, bool) = (1, 2 as i64, true);
    let a: i32 = t.0;
    let b: i64 = t.1;
    let c: bool = t.2;
    return a;
}

struct Point {
    x: i32,
    y: i32
}

fn test_struct_ops() -> i32 {
    let p: Point = Point { x: 10, y: 20 };
    let a: i32 = p.x;
    let b: i32 = p.y;
    
    let mut p2: Point = Point { x: 0, y: 0 };
    p2.x = 100;
    p2.y = 200;
    
    return a + b + p2.x;
}

fn test_casts() -> i32 {
    let a: i32 = 100;
    let b: i64 = a as i64;
    let c: u32 = a as u32;
    let d: f64 = a as f64;
    let e: i32 = d as i32;
    let f: u8 = a as u8;
    return e;
}

fn test_logical_ops() -> i32 {
    let a: bool = true && false;
    let b: bool = true || false;
    let c: bool = !a;
    return 0;
}

fn test_assign_ops() -> i32 {
    let mut x: i32 = 10;
    x += 5;
    x -= 3;
    x *= 2;
    x /= 4;
    x %= 3;
    
    let mut y: i32 = 0xFF;
    y &= 0x0F;
    y |= 0xF0;
    y ^= 0xFF;
    
    return x + y;
}

fn test_references() -> i32 {
    let x: i32 = 42;
    let r: &i32 = &x;
    let v: i32 = *r;
    
    let mut y: i32 = 100;
    let mr: &mut i32 = &mut y;
    *mr = 200;
    
    return v + y;
}

fn test_intrinsics() -> i32 {
    let a: i32 = 0b11010011;
    let b: i32 = a.popcount();
    let c: i32 = a.leading_zeros();
    
    return b + c;
}

fn main() -> i32 {
    let r1: i32 = test_all_primitives();
    let r2: i32 = test_arithmetic_all_types();
    let r3: i32 = test_comparisons();
    let r4: i32 = test_bitwise_ops();
    let r5: i32 = test_unary_ops();
    let r6: i32 = test_control_flow();
    let r7: i32 = test_array_ops();
    let r8: i32 = test_tuple_ops();
    let r9: i32 = test_struct_ops();
    let r10: i32 = test_casts();
    let r11: i32 = test_logical_ops();
    let r12: i32 = test_assign_ops();
    let r13: i32 = test_references();
    let r14: i32 = test_intrinsics();
    return 0;
}
