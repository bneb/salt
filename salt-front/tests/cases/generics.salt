// Comprehensive Generic Types and Functions
package tests.generics

struct Box<T> { value: T }

impl Box<i32> {
    fn get(self) -> i32 { return self.value; }
}

struct Pair<T, U> { first: T, second: U }

fn test_generic_struct() -> i32 {
    let b = Box::<i32> { value: 10 };
    return b.get();
}

fn test_multi_generic() -> i32 {
    let p = Pair::<i32, f64> { first: 1, second: 2.5 };
    return p.first;
}

fn identity<T>(val: T) -> T {
    return val;
}

fn main() -> i32 {
    let r1 = test_generic_struct();
    let r2 = test_multi_generic();
    let r3 = identity::<i32>(42);
    return 0;
}
