// Targeting pulse attribute and hot path annotations

@hot
fn hot_arithmetic() -> i32 {
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 100 {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

fn pulsed_function() -> i32 {
    let x: i32 = 42;
    return x * 2;
}

fn call_hot_and_pulse() -> i32 {
    let a: i32 = hot_arithmetic();
    let b: i32 = pulsed_function();
    return a + b;
}

fn main() -> i32 {
    return call_hot_and_pulse();
}
