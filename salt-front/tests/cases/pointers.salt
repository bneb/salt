// Comprehensive Pointer and Reference Operations
package tests.pointers

fn test_ref_deref() -> i32 {
    let mut x: i32 = 42;
    let r: &mut i32 = &mut x;
    *r = 100;
    return x;
}

fn test_ptr_comparisons() -> bool {
    let x = 10;
    let y = 10;
    let px = &x;
    let py = &y;
    return px == py; // This checks address identity in Salt for references
}

fn main() -> i32 {
    let r1 = test_ref_deref();
    let r2 = test_ptr_comparisons();
    return 0;
}
