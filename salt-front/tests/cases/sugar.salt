// Comprehensive Syntactic Sugar and High-Level Features
package tests.sugar

struct Point { x: i32, y: i32 }
struct Registry { p: Point }

fn takes_tuple(t: (i32, i32)) -> i32 {
    let (a, b) = t;
    return a + b;
}

fn takes_point(p: Point) -> i32 {
    return p.x + p.y;
}

fn test_tuples() -> i32 {
    let t = (10, 20);
    return takes_tuple(t);
}

fn test_destructuring() -> i32 {
    let p = Point { x: 1, y: 2 };
    let Point { x: a, y: b } = p;
    return a + b;
}

fn test_explicit_blocks() -> i32 {
    let x: i32 = {
        let tmp: i32 = 10;
        tmp + 5
    };
    return x;
}

fn test_string_literals() -> i32 {
    let s: &str = "hello world";
    return 0;
}

fn test_inference() -> i32 {
    let x = 10; // i32 by default
    let y = 3.14; // f32 by default
    return x;
}

fn main() -> i32 {
    let r1 = test_tuples();
    let r2 = test_destructuring();
    let r3 = test_explicit_blocks();
    let r4 = test_string_literals();
    let r5 = test_inference();
    return 0;
}
