// Targeting uncovered tuple field access via pointer paths (lines 1594-1617)

fn test_tuple_field_pointer() -> i32 {
    let mut t: (i32, i32, i32) = (10, 20, 30);
    let r: &mut (i32, i32, i32) = &mut t;
    
    // Access tuple fields via deref
    let x: i32 = t.0;
    let y: i32 = t.1;
    let z: i32 = t.2;
    
    return x + y + z;
}

fn test_tuple_field_assign() -> i32 {
    let mut t: (i32, i32) = (0, 0);
    t.0 = 100;
    t.1 = 200;
    return t.0 + t.1;
}

fn test_nested_tuple_access() -> i32 {
    let t: (i32, (i32, i32)) = (1, (2, 3));
    let inner: (i32, i32) = t.1;
    return t.0 + inner.0 + inner.1;
}

fn main() -> i32 {
    let r1: i32 = test_tuple_field_pointer();
    let r2: i32 = test_tuple_field_assign();
    let r3: i32 = test_nested_tuple_access();
    return r1 + r2 + r3;
}
