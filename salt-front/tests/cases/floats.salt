// Comprehensive Floating Point Operations
package tests.floats

fn test_f32_arithmetic(a: f32, b: f32) -> f32 {
    let c = a + b;
    let d = a - b;
    let e = a * b;
    let f = a / b;
    return c + d + e + f;
}

fn test_f64_arithmetic(a: f64, b: f64) -> f64 {
    let c = a + b;
    let d = a - b;
    let e = a * b;
    let f = a / b;
    let g = -a;
    return c + d + e + f + g;
}

fn test_float_comparisons(a: f32, b: f32) -> bool {
    if a > b { return true; }
    if a < b { return true; }
    if a == b { return true; }
    return false;
}

fn main() -> i32 {
    let r1 = test_f32_arithmetic(10.0, 2.0);
    let r2 = test_f64_arithmetic(20.0, 4.0);
    let r3 = test_float_comparisons(1.0, 2.0);
    return 0;
}
