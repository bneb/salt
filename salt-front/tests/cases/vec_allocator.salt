// TDD Test: Vec<T, A> with HeapAllocator
// Phase 1: Validate heap-backed vector end-to-end
package main

import std.mem.allocator.HeapAllocator;
import std.collections.vec.Vec;

pub fn main() -> i32 {
    println("Test: HeapAllocator Vec<i64>");
    let heap_alloc = HeapAllocator { _pad: 0 };
    let mut v = Vec::<i64, HeapAllocator>::new(heap_alloc, 2);

    v.push(10);
    v.push(20);
    v.push(30);  // Triggers grow (cap 2 -> 4 via realloc)

    let mut result = 0;

    if v.len() != 3 { println("FAIL: len"); result = 1; }
    if v.get(0) != 10 { println("FAIL: get(0)"); result = 1; }
    if v.get(1) != 20 { println("FAIL: get(1)"); result = 1; }
    if v.get(2) != 30 { println("FAIL: get(2)"); result = 1; }

    v.push(40);
    v.push(50);  // Triggers grow again (cap 4 -> 8)
    if v.len() != 5 { println("FAIL: len after grow"); result = 1; }
    if v.get(4) != 50 { println("FAIL: get(4)"); result = 1; }

    v.free();
    if result == 0 { println("PASS: HeapAllocator Vec"); }
    return result;
}
