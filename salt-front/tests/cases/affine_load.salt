// Full coverage: affine.load in affine context
package main

fn main() -> i32 {
    let a = Tensor::<f64>(1.0, [64, 64]);
    let mut sum = 0.0;
    for i in 0..64 {
        for j in 0..64 {
            sum += a[(i, j)];  // Should emit affine.load
        }
    }
    // 64 * 64 * 1.0 = 4096.0
    if sum > 4095.0 { return 0; }
    return 1;
}
