// Full coverage: affine.store in affine context
package main

fn main() -> i32 {
    let mut res = Tensor::<f64>(0.0, [64, 64]);
    for i in 0..64 {
        for j in 0..64 {
            res[(i, j)] = 1.0;  // Should emit affine.store
        }
    }
    if res[(0, 0)] > 0.0 { return 0; }
    return 1;
}
