// Bug 1: Paren wrapping on tuple indices
// The parser wraps (i, j) in syn::Expr::Paren before the inner Tuple
package main

fn main() -> i32 {
    let a = Tensor::<f64>(1.0, [4, 4]);
    let val = a[(1, 2)];  // Should compile - tuple index wrapped in parens
    if val > 0.0 { return 0; }
    return 1;
}
