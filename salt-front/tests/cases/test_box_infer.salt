package main

// TDD: Comprehensive Box::new inference tests
// Tests the class of issues where struct literal type resolution
// must correctly qualify names with package prefix.
//
// Case 1: Simple struct (no generic fields)
// Case 2: Struct with Ptr<T> fields (recursive, generic-containing fields)
// Case 3: Multiple Box::new calls with different struct types

import std.core.ptr.Ptr
import std.core.boxed.Box

struct Simple { val: i32 }

struct Node {
    val: i32,
    left: Ptr<Node>,
    right: Ptr<Node>
}

struct ListNode {
    data: i64,
    next: Ptr<ListNode>
}

fn main() -> i32 {
    // Case 1: Simple struct literal
    let b1 = Box::new(Simple { val: 10 });
    let s1 = b1.read();
    println(f"simple: {s1.val as i64}");
    b1.drop();

    // Case 2: Struct with Ptr<T> fields (recursive)
    let b2 = Box::new(Node {
        val: 42,
        left: Ptr::<Node>::empty(),
        right: Ptr::<Node>::empty()
    });
    let n = b2.read();
    println(f"node: {n.val as i64}");
    b2.drop();

    // Case 3: Different struct type in same function
    let b3 = Box::new(ListNode {
        data: 99,
        next: Ptr::<ListNode>::empty()
    });
    let ln = b3.read();
    println(f"list: {ln.data}");
    b3.drop();

    return 0;
}
