// Comprehensive Integer and Arithmetic Operations
package tests.integers

fn test_basic_arithmetic() -> i32 {
    let a = 10;
    let b = 20;
    let c = a + b * 2;
    let d = c - 5;
    let e = d / 2;
    let f = e % 3;
    return f;
}

fn test_assign_ops() -> i32 {
    let mut x = 10;
    x += 5;
    x -= 2;
    x *= 2;
    x /= 3;
    x %= 5;
    return x;
}

fn test_i8_full() -> i32 {
    let a: i8 = 50 as i8;
    let b: i8 = 20 as i8;
    let c: i8 = a + b;
    let d: i8 = a - b;
    let e: i8 = a * 2 as i8;
    let f: i8 = a / 2 as i8;
    return c as i32 + d as i32;
}

fn test_u64_full() -> i32 {
    let a: u64 = 1000000 as u64;
    let b: u64 = 500000 as u64;
    let c: u64 = a + b;
    let d: u64 = a - b;
    let e: u64 = a * 2 as u64;
    return c as i32;
}

fn test_shifts() -> i32 {
    let a: i32 = 1;
    let b: i32 = a << 4;
    let c: i32 = b >> 2;
    return b + c;
}

fn test_popcount() -> i32 {
    let a: i32 = 123;
    return a.popcount();
}

fn test_bitwise() -> i32 {
    let a: i32 = 0xFF;
    let b: i32 = 0x0F;
    let c: i32 = a & b;
    let d: i32 = a | b;
    let e: i32 = a ^ b;
    let f: i32 = !a;
    return c + d + e;
}

fn main() -> i32 {
    let r1 = test_basic_arithmetic();
    let r2 = test_assign_ops();
    let r3 = test_i8_full();
    let r4 = test_u64_full();
    let r5 = test_shifts();
    let r6 = test_popcount();
    let r7 = test_bitwise();
    return 0;
}
