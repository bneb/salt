// Error path coverage for codegen.rs

fn test_string_literals() -> i32 {
    let s: &str = "hello world";
    return 0;
}

fn test_explicit_blocks() -> i32 {
    let x: i32 = {
        let tmp: i32 = 10;
        tmp + 5
    };
    return x;
}

fn test_method_on_primitive() -> i32 {
    let a: i32 = 123;
    let b: i32 = a.popcount();
    return b;
}

fn test_ref_deref() -> i32 {
    let mut x: i32 = 42;
    let r: &mut i32 = &mut x;
    *r = 100;
    return x;
}

fn test_neg_float() -> i32 {
    let a: f64 = 3.14;
    let b: f64 = -a;
    return b as i32;
}

fn test_for_loop_range() -> i32 {
    let mut sum: i32 = 0;
    for i in 0..10 {
        sum = sum + 1;
    }
    return sum;
}

fn test_nested_if() -> i32 {
    let x: i32 = 5;
    if x > 3 {
        if x > 4 {
            return 1;
        } else {
            return 2;
        }
    }
    return 0;
}

fn test_index_assign() -> i32 {
    let mut arr: [i32; 5] = [0, 0, 0, 0, 0];
    arr[2] = 42;
    return arr[2];
}

fn test_floating_ops() -> i32 {
    let a: f64 = 10.5;
    let b: f64 = 3.5;
    let sum: f64 = a + b;
    let diff: f64 = a - b;
    let prod: f64 = a * b;
    let quot: f64 = a / b;
    return sum as i32;
}

fn main() -> i32 {
    let r1: i32 = test_string_literals();
    let r2: i32 = test_explicit_blocks();
    let r3: i32 = test_method_on_primitive();
    let r4: i32 = test_ref_deref();
    let r5: i32 = test_neg_float();
    let r6: i32 = test_for_loop_range();
    let r7: i32 = test_nested_if();
    let r8: i32 = test_index_assign();
    let r9: i32 = test_floating_ops();
    return 0;
}
