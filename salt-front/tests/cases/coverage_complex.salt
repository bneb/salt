// Targeting complex expression and statement paths

fn test_complex_if_return() -> i32 {
    let x: i32 = 5;
    let y: i32 = 10;
    
    if x < y {
        if x > 0 {
            if y < 20 {
                return 1;
            }
            return 2;
        }
        return 3;
    } else {
        if y > 5 {
            return 4;
        }
        return 5;
    }
    return 0;
}

fn test_bool_logic_chain() -> i32 {
    let a: i32 = 5;
    let b: i32 = 10;
    let c: i32 = 15;
    
    if a < b && b < c {
        return 1;
    }
    if a > b || b > c {
        return 2;
    }
    return 0;
}

fn test_nested_loops_with_break() -> i32 {
    let mut count: i32 = 0;
    let mut i: i32 = 0;
    
    while i < 10 {
        let mut j: i32 = 0;
        while j < 10 {
            count = count + 1;
            if j == 5 {
                break;
            }
            j = j + 1;
        }
        if i == 3 {
            break;
        }
        i = i + 1;
    }
    return count;
}

fn test_many_assignments() -> i32 {
    let mut a: i32 = 0;
    a = 1;
    a = a + 1;
    a = a * 2;
    a = a - 1;
    a = a / 2;
    a = a % 3;
    a = a << 1;
    a = a >> 1;
    a = a & 0xFF;
    a = a | 0x01;
    a = a ^ 0x01;
    return a;
}

fn test_function_chain() -> i32 {
    return step4();
}

fn step1() -> i32 {
    return 1;
}

fn step2() -> i32 {
    return step1() + 1;
}

fn step3() -> i32 {
    return step2() + 1;
}

fn step4() -> i32 {
    return step3() + 1;
}

fn test_array_mutation() -> i32 {
    let mut arr: [i32; 5] = [0, 0, 0, 0, 0];
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    arr[4] = 50;
    return arr[0] + arr[1] + arr[2] + arr[3] + arr[4];
}

fn main() -> i32 {
    let r1: i32 = test_complex_if_return();
    let r2: i32 = test_bool_logic_chain();
    let r3: i32 = test_nested_loops_with_break();
    let r4: i32 = test_many_assignments();
    let r5: i32 = test_function_chain();
    let r6: i32 = test_array_mutation();
    return r1 + r2 + r3 + r4 + r5 + r6;
}
