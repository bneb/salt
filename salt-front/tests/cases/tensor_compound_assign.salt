// Bug 2: Index evaluation before Tensor type check
// Compound assignment on tensor should emit affine.store, not crash on tuple promotion
package main

fn main() -> i32 {
    let mut res = Tensor::<f64>(0.0, [4, 4]);
    for i in 0..4 {
        for j in 0..4 {
            res[(i, j)] += 1.0;  // Should trigger affine.store, not crash
        }
    }
    if res[(0, 0)] > 0.0 { return 0; }
    return 1;
}
