// Test: @pure function calls in requires clause
// Verifies that @pure functions can be used in preconditions.
// Z3 models them as uninterpreted functions.
//
// OUTPUT: pure_verify: PASS

@pure
fn is_positive(x: i64) -> bool {
    return x > 0;
}

fn safe_div(a: i64, b: i64) -> i64
    requires { is_positive(b) }
{
    return a / b;
}

fn main() -> i32 {
    let r = safe_div(10, 2);
    println("pure_verify: PASS");
    return 0;
}
