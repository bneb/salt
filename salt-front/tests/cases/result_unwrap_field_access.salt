// Minimal test for Result::unwrap + field access bug
package main

enum Result<T, E> {
    Ok(T),
    Err(E)
}

impl<T, E> Result<T, E> {
    pub fn unwrap(self) -> T {
        return match self {
            Result::Ok(v) => v,
            Result::Err(_) => self.unwrap()
        };
    }
}

struct Ptr {
    inner: i64,
    size: i64
}

fn main() -> i32 {
    let r = Result::<Ptr, i32>::Ok(Ptr { inner: 42, size: 10 });
    
    // This should access .inner on the Ptr returned by unwrap()
    let val = r.unwrap().inner;
    
    if val == 42 {
        return 0;
    }
    return 1;
}
