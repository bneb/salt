// Test: HashMap iteration — iter(), keys(), values()
// Verifies that we can iterate over all entries in a HashMap
// using the iterator protocol (while + next() + let-else)
//
// OUTPUT: === HashMap Iteration Tests ===
// OUTPUT: iter count == 5  ... PASS
// OUTPUT: iter sum keys == 15  ... PASS
// OUTPUT: iter sum vals == 150  ... PASS
// OUTPUT: empty iter count == 0  ... PASS
// OUTPUT: post-remove iter count == 4  ... PASS
// OUTPUT: ALL TESTS PASSED

import std.collections.hash_map.HashMap
import std.collections.hash_map.Entry
import std.collections.hash_map.HashMapIter
import std.core.option.Option

fn main() -> i32 {
    let mut passed: i64 = 0;
    let mut failed: i64 = 0;

    println("=== HashMap Iteration Tests ===");

    // =========================================================================
    // Test 1: iter() count — use large capacity to avoid triggering grow()
    // =========================================================================
    let mut m = HashMap::<i64, i64>::with_capacity(32);
    m.insert(1, 10);
    m.insert(2, 20);
    m.insert(3, 30);
    m.insert(4, 40);
    m.insert(5, 50);

    let mut count: i64 = 0;
    let mut iter = m.iter();
    while true {
        let Option::Some(entry) = iter.next() else { break; };
        count += 1;
    }

    print("iter count == 5");
    if count == 5 { println("  ... PASS"); passed += 1; } else { println(f"  ... FAIL (got {count})"); failed += 1; }

    // =========================================================================
    // Test 2: iter() key sum
    // =========================================================================
    let mut key_sum: i64 = 0;
    let mut iter2 = m.iter();
    while true {
        let Option::Some(entry) = iter2.next() else { break; };
        key_sum += entry.key;
    }

    print("iter sum keys == 15");
    if key_sum == 15 { println("  ... PASS"); passed += 1; } else { println(f"  ... FAIL (got {key_sum})"); failed += 1; }

    // =========================================================================
    // Test 3: iter() value sum
    // =========================================================================
    let mut val_sum: i64 = 0;
    let mut iter3 = m.iter();
    while true {
        let Option::Some(entry) = iter3.next() else { break; };
        val_sum += entry.val;
    }

    print("iter sum vals == 150");
    if val_sum == 150 { println("  ... PASS"); passed += 1; } else { println(f"  ... FAIL (got {val_sum})"); failed += 1; }

    // =========================================================================
    // Test 4: Empty map iteration
    // =========================================================================
    let empty = HashMap::<i64, i64>::new();
    let mut empty_count: i64 = 0;
    let mut iter4 = empty.iter();
    while true {
        let Option::Some(_) = iter4.next() else { break; };
        empty_count += 1;
    }

    print("empty iter count == 0");
    if empty_count == 0 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // =========================================================================
    // Test 5: Iteration after remove
    // =========================================================================
    let rk: i64 = 3;
    m.remove(&rk);

    let mut post_remove_count: i64 = 0;
    let mut iter5 = m.iter();
    while true {
        let Option::Some(_) = iter5.next() else { break; };
        post_remove_count += 1;
    }

    print("post-remove iter count == 4");
    if post_remove_count == 4 { println("  ... PASS"); passed += 1; } else { println(f"  ... FAIL (got {post_remove_count})"); failed += 1; }

    m.drop();

    // =========================================================================
    // Summary
    // =========================================================================
    if failed == 0 {
        println("ALL TESTS PASSED");
    } else {
        println("SOME TESTS FAILED");
    }

    return failed as i32;
}
