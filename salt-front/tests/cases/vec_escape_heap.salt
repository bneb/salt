// vec_escape_heap.salt — POSITIVE TEST
// Expected: Compiles successfully with NO errors.
// A heap-backed Vec CAN be returned from any function because
// HeapAllocator uses malloc/free which has global lifetime.
package main

import std.mem.allocator.HeapAllocator;
import std.collections.vec.Vec;

pub fn main() -> i32 {
    println("Test: HeapAllocator Vec Escape");
    let alloc = HeapAllocator { _pad: 0 };
    let mut v = Vec::<i64, HeapAllocator>::new(alloc, 4);
    v.push(10);
    v.push(20);
    v.push(30);

    let mut result = 0;
    if v.get(0) != 10 { println("FAIL: get(0)"); result = 1; }
    if v.get(1) != 20 { println("FAIL: get(1)"); result = 1; }
    if v.get(2) != 30 { println("FAIL: get(2)"); result = 1; }

    v.free();

    if result == 0 {
        println("PASS: HeapAllocator Vec Escape");
    }
    return result;
}
