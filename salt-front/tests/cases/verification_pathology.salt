
// Verification Pathology Test Suite
// Targets: Z3Verify.cpp (UNSAT paths, Timeouts)

// ==========================================
// 1. UNSAT Paths
// ==========================================

// Contradictory range constraints
// Z3 should determine this path is impossible if x constraints are propagated
fn target_unsat_range(x: i32) -> i32 {
    if x > 100 {
        if x < 50 {
            // Unreachable
            return -1; 
        }
    }
    return 0;
}

// Contradictory arithmetic
fn target_unsat_arith(a: i32, b: i32) -> i32 {
    if a > 0 && b > 0 {
        if (a + b) < 0 {
             // Impossible for positive i32 unless overflow (which Z3 might model if we tell it)
             // If we model wrapping, this IS possible. If we model unbounded math, it's not.
             // Salt currently models wrapping semantics usually, but let's try logical contradiction.
             // (a + b) < a where b > 0.
             if (a + b) < a {
                 // Overflow case? Or strictly impossible in mathematical integer domain
                 return 1;
             }
        }
    }
    return 0;
}

// ==========================================
// 2. Boundary Timeouts / Complexity
// ==========================================

// Non-linear arithmetic (multiplication) is hard for solvers
fn target_complexity_nonlinear(x: i32, y: i32, z: i32) -> i32 {
    // Pythagorean triple check - likely hard to prove UNSAT or satisfy for generic large ranges
    if (x*x) + (y*y) == (z*z) {
        if x > 1000 && y > 1000 && z > 1000 {
            if x != y && y != z {
                return 1;
            }
        }
    }
    return 0;
}

// Bit-vector overflow logic
fn target_bit_paradox(x: u32) -> i32 {
    // For unsigned u32, (x << 1) can be smaller than x if it overflows.
    // However, if we add constraints that prevent overflow, can Z3 prove it?
    if x < 0x80000000 {
        if (x << 1) < x {
            // Impossible path for x < 0x80000000
            return 1;
        }
    }
    
    // Population count parity (hard for some solver configurations)
    let y = x ^ (x >> 1);
    if y == 0xFFFFFFFF {
        return 2;
    }
    
    return 0;
}

// Higher-order non-linear constraints
fn target_nonlinear_depth(x: i32, y: i32, z: i32, w: i32) -> i32 {
    if x > 0 && y > 0 && z > 0 && w > 0 {
        if (x * y * z) == w {
            if w < 0 {
                // Impossible for positive x,y,z unless overflow
                return 1;
            }
        }
    }
    return 0;
}

// Deep boolean chain (classic SAT hardness)
fn target_sat_hardness(a: bool, b: bool, c: bool, d: bool, e: bool, f: bool) -> i32 {
    // complex DNF/CNF
    if (a || b || c) && (!a || !b || d) && (d || e || !f) && (!d || !e || f) && (a || !c || !e) {
        // Solving this requires checking combinations
        return 1;
    }
    return 0;
}

// 3. Structural Complexity
// ==========================================

struct Node {
    next: Owned<Node>,
    val: i32
}

// Deeply nested access to trigger recursive walk limits in Z3 backend
fn target_recursion_depth(n: Node) -> i32 {
    // 33 levels deep access (limit is 33)
    return n.next.next.next.next.next.next.next.next.next.next.
           next.next.next.next.next.next.next.next.next.next.
           next.next.next.next.next.next.next.next.next.next.
           next.next.next.val;
}

// 4. Advanced Bit Logic
// ==========================================
fn target_bit_advanced(x: u32) -> i32 {
    // popcount of u32 > 32 is impossible
    if popcount(x) > 32 {
        return 1;
    }
    
    // x & (x - 1) is 0 iff x is a power of 2
    if x > 0 && (x & (x - 1)) == 0 {
        if popcount(x) != 1 {
            // Contradiction: power of 2 must have exactly 1 bit set
            return 2;
        }
    }
    
    return 0;
}

public fn main() -> i32 {
    let u1 = target_unsat_range(10);
    let u2 = target_unsat_arith(10, 20);
    let c1 = target_complexity_nonlinear(3, 4, 5);
    let c2 = target_sat_hardness(true, false, true, false, true, false);
    let b1 = target_bit_paradox(12345);
    let n1 = target_nonlinear_depth(2, 3, 4, 24);
    let r1 = target_bit_advanced(42);
    // Note: main cannot easily call target_recursion_depth without constructing a deep list,
    // but the verification pass will check the function definition regardless of call sites in main
    // if it's an inter-procedural pass.
    return u1 + u2 + c1 + c2 + b1 + n1 + r1;
}
