fn main() -> i32 {
    let mut i: i32 = 0;
    let mut sum: i32 = 0;
    
    // If 'i' is treated as SSA (immutable) due to the ': i32' type annotation,
    // this loop condition 'i < 10' will always read the initial value '0',
    // resulting in an infinite loop (or timeout in value-based testing).
    while i < 10 {
        sum = sum + i;
        i = i + 1;
    }

    // Sum of 0..9 is 45
    if sum == 45 {
        if i == 10 {
            return 0;
        }
    }
    return 1;
}
