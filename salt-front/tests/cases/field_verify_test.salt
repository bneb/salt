// Test: Field access in requires clause
// Verifies that Z3 can reason about struct fields (self.len, buf.cap).
// This should compile successfully — the requires clause should be verifiable.
//
// OUTPUT: field_verify: PASS

struct Buffer {
    len: i64,
    cap: i64,
}

fn get(buf: Buffer, idx: i64) -> i64
    requires { idx >= 0 && idx < buf.len }
{
    return idx;
}

fn main() -> i32 {
    let b = Buffer { len: 10, cap: 20 };
    let v = get(b, 5);
    println("field_verify: PASS");
    return 0;
}
