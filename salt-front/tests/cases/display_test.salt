// Test: Display trait - f-string with custom types
// Verifies that structs with fmt() work in f-strings via println
//
// OUTPUT: === Display Trait Tests ===
// OUTPUT: Point: (10, 20)
// OUTPUT: Integer: 42
// OUTPUT: Negative: -7
// OUTPUT: Bool true: true
// OUTPUT: Bool false: false
// OUTPUT: ALL TESTS PASSED

import std.core.fmt.Formatter
import std.string.String

struct Point {
    x: i64,
    y: i64
}

impl Point {
    fn fmt(&self, f: &mut Formatter) {
        f.write("(", 1);
        f.write_i64(self.x);
        f.write(", ", 2);
        f.write_i64(self.y);
        f.write(")", 1);
    }
}

fn main() -> i32 {
    println("=== Display Trait Tests ===");

    // Custom struct Display via f-string in println
    let p = Point { x: 10, y: 20 };
    println(f"Point: {p}");

    // Primitive i64 in f-string
    let n: i64 = 42;
    println(f"Integer: {n}");

    // Negative i64
    let neg: i64 = -7;
    println(f"Negative: {neg}");

    // Bool in f-string
    let b1 = true;
    println(f"Bool true: {b1}");

    let b2 = false;
    println(f"Bool false: {b2}");

    println("ALL TESTS PASSED");
    return 0;
}
