package main

// Test 3: Box::as_ptr() returns a valid pointer
// Expected: prints "99" (value accessed via the inner pointer)

import std.core.ptr.Ptr
import std.core.boxed.Box

extern fn free(ptr: u64);

struct Item { val: i32 }

fn main() -> i32 {
    let b = Box::<Item>::new(Item { val: 99 });
    let p = b.as_ptr();
    let item = p.read();
    println(f"val: {item.val as i64}");
    free(p.addr());
    return 0;
}
