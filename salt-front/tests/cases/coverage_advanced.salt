// Additional codegen coverage: Status type, generics, enums, and more
enum Result<T, E> {
    Ok(T),
    Err(E)
}

fn test_enum_construction() -> i32 {
    let ok: Result<i32, i32> = Result::<i32, i32>::Ok(42);
    let err: Result<i32, i32> = Result::<i32, i32>::Err(1);
    return 0;
}

fn test_match_enum() -> i32 {
    let val: Result<i32, i32> = Result::<i32, i32>::Ok(100);
    match val {
        Result::Ok(v) => return v,
        Result::Err(e) => return e
    }
    return 0;
}

struct GenericBox<T> {
    value: T
}

fn test_generic_struct() -> i32 {
    let box_i32: GenericBox<i32> = GenericBox::<i32> { value: 42 };
    let box_i64: GenericBox<i64> = GenericBox::<i64> { value: 100 as i64 };
    return box_i32.value;
}

fn add<T>(a: T, b: T) -> T {
    return a + b;
}

fn test_generic_fn() -> i32 {
    let r1: i32 = add::<i32>(10, 20);
    let r2: i64 = add::<i64>(100 as i64, 200 as i64);
    return r1;
}

fn test_nested_loops() -> i32 {
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 3 {
        let mut j: i32 = 0;
        while j < 3 {
            sum = sum + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    return sum;
}

fn test_break_continue() -> i32 {
    let mut x: i32 = 0;
    let mut i: i32 = 0;
    while i < 10 {
        i = i + 1;
        if i == 5 {
            break;
        }
    }
    return x;
}

fn test_pointer_casts() -> i32 {
    let x: i32 = 42;
    let p: &i32 = &x;
    return *p;
}

fn test_float_comparisons() -> i32 {
    let a: f64 = 1.5;
    let b: f64 = 2.5;
    let c: bool = a < b;
    let d: bool = a > b;
    let e: bool = a == b;
    let f: bool = a != b;
    let g: bool = a <= b;
    let h: bool = a >= b;
    return 0;
}

fn test_unsigned_ops() -> i32 {
    let a: u32 = 100 as u32;
    let b: u32 = 30 as u32;
    let c: u32 = a / b;
    let d: u32 = a % b;
    let e: bool = a > b;
    let f: bool = a < b;
    let g: bool = a >= b;
    let h: bool = a <= b;
    return c as i32;
}

fn main() -> i32 {
    let r1: i32 = test_enum_construction();
    let r2: i32 = test_match_enum();
    let r3: i32 = test_generic_struct();
    let r4: i32 = test_generic_fn();
    let r5: i32 = test_nested_loops();
    let r6: i32 = test_break_continue();
    let r7: i32 = test_pointer_casts();
    let r8: i32 = test_float_comparisons();
    let r9: i32 = test_unsigned_ops();
    return 0;
}
