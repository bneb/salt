// Comprehensive Equality and Comparison Operations
package tests.equality

struct Point { x: i32, y: i32 }

fn test_scalar_equality() -> bool {
    let a = 10;
    let b = 10;
    return a == b;
}

fn test_struct_equality() -> bool {
    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 1, y: 2 };
    return p1 == p2;
}

fn main() -> i32 {
    let r1 = test_scalar_equality();
    let r2 = test_struct_equality();
    return 0;
}
