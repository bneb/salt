// Comprehensive Method and Sugar Features
package tests.methods

struct Point { x: i32, y: i32 }

impl Point {
    fn new(x: i32, y: i32) -> Point {
        return Point { x: x, y: y };
    }

    fn shift(&mut self, dx: i32, dy: i32) {
        self.x += dx;
        self.y += dy;
    }

    fn dist_sq(self) -> i32 {
        return self.x * self.x + self.y * self.y;
    }

    fn area(&self) -> i32 {
        return self.x * self.y;
    }
}

fn test_basic_methods() -> i32 {
    let mut p = Point::new(10, 20);
    p.shift(5, 5);
    return p.x + p.y;
}

fn test_sugar_methods() -> i32 {
    let p = Point { x: 3, y: 4 };
    return p.dist_sq();
}

fn main() -> i32 {
    let r1 = test_basic_methods();
    let r2 = test_sugar_methods();
    return 0;
}
