// Comprehensive Ptr field access regression test
// Tests multiple primitive type parameters to catch monomorphization issues
// Issue: Stale .val field name was causing compilation failures
package main

// --- Ptr struct (matches stdlib inner/size fields) ---
pub struct Ptr<T> {
    inner: &T,
    size: i64
}

// === PRIMITIVE TYPE PARAMETERIZATION ===

// Test 1: Ptr<i64> field access
fn test_ptr_i64() -> bool {
    let val: i64 = 42;
    let ptr = Ptr::<i64> { inner: &val, size: 8 };
    return ptr.size == 8;
}

// Test 2: Ptr<i32> field access (different T)
fn test_ptr_i32() -> bool {
    let val: i32 = 100;
    let ptr = Ptr::<i32> { inner: &val, size: 4 };
    return ptr.size == 4;
}

// Test 3: Ptr<f64> field access (floating point)
fn test_ptr_f64() -> bool {
    let val: f64 = 3.14159;
    let ptr = Ptr::<f64> { inner: &val, size: 8 };
    return ptr.size == 8;
}

// Test 4: Ptr<u8> field access (byte)
fn test_ptr_u8() -> bool {
    let val: u8 = 255;
    let ptr = Ptr::<u8> { inner: &val, size: 1 };
    return ptr.size == 1;
}

// --- Main: Run all tests ---
fn main() -> i32 {
    let mut passed = 0;
    
    if test_ptr_i64() { passed += 1; }
    if test_ptr_i32() { passed += 1; }
    if test_ptr_f64() { passed += 1; }
    if test_ptr_u8() { passed += 1; }
    
    // Return 0 if all 4 tests pass
    if passed == 4 {
        return 0;
    }
    return 4 - passed;
}
