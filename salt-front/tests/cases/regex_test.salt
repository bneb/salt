// Test: Regex module — POSIX regex via C bridge
// Verifies pattern compilation and matching.
//
// OUTPUT: === Regex Tests ===
// OUTPUT: test_compile: PASS
// OUTPUT: test_match_simple: PASS
// OUTPUT: test_no_match: PASS
// OUTPUT: test_match_email: PASS
// OUTPUT: test_invalid_pattern: PASS
// OUTPUT: ALL TESTS PASSED

import std.regex.Regex

fn main() -> i32 {
    println("=== Regex Tests ===");

    // Test 1: Compile a valid pattern
    let mut re = Regex::new("hello\0");
    if re.is_valid() {
        println("test_compile: PASS");
    } else {
        println("test_compile: FAIL");
    }
    re.drop();

    // Test 2: Simple match
    let mut re2 = Regex::new("^[0-9]+$\0");
    if re2.is_match("12345\0") {
        println("test_match_simple: PASS");
    } else {
        println("test_match_simple: FAIL");
    }

    // Test 3: No match
    if re2.is_match("abc\0") {
        println("test_no_match: FAIL");
    } else {
        println("test_no_match: PASS");
    }
    re2.drop();

    // Test 4: Email-like pattern
    let mut re3 = Regex::new("[a-zA-Z0-9]+@[a-zA-Z0-9]+\\.[a-z]+\0");
    if re3.is_match("user@example.com\0") {
        println("test_match_email: PASS");
    } else {
        println("test_match_email: FAIL");
    }
    re3.drop();

    // Test 5: Invalid pattern should not compile
    let mut re4 = Regex::new("[invalid\0");
    if re4.is_valid() {
        println("test_invalid_pattern: FAIL");
    } else {
        println("test_invalid_pattern: PASS");
    }
    re4.drop();

    println("ALL TESTS PASSED");
    return 0;
}
