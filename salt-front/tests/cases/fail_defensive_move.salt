struct Node { val: i32 }
extern fn alloc() -> owned Node;

fn main() -> i32 {
    let n = alloc();
    let m = n; // Moves n to m
    let o = n; // Error: Use of moved value 'n'
    
    // To avoid leak error for m (if compiler continues), we should probably consume m?
    // But Salt stops at first error usually.
    return 0;
}
