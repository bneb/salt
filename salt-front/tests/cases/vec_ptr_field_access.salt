// Regression test: Ptr struct field access with 'inner' field
// Tests that Ptr{inner, size} fields are correctly resolved
// Issue: Hardcoded "val" in emit_lvalue was causing field lookup failures
package main

struct Ptr<T> {
    inner: &T,
    size: i64
}

impl<T> Ptr<T> {
    pub fn from_raw(addr: &T, sz: i64) -> Ptr<T> {
        return Ptr { inner: addr, size: sz };
    }
    
    pub fn get_inner(self) -> &T {
        return self.inner;
    }
}

fn main() -> i32 {
    let value: i64 = 12345;
    let ptr = Ptr::<i64>::from_raw(&value, 8);
    
    // Test field access on Ptr struct
    let inner_ref = ptr.inner;
    let sz = ptr.size;
    
    // Test method that accesses inner field
    let inner2 = ptr.get_inner();
    
    if sz == 8 {
        return 0;  // Success
    }
    return 1;  // Failure
}
