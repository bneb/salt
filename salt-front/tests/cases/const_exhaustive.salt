
// Exhaustive Const Test

// 1. Basic Types & Hex
const C_INT: i32 = 100;
const C_HEX: u32 = 0x3F8; // 1016
const C_FLOAT: f64 = 1.5;
const C_BOOL: bool = true;

// 2. Binary Operations
const C_ADD: i32 = 10 + 20; // 30
const C_SUB: i32 = 100 - 50; // 50
const C_MUL: i32 = 5 * 6; // 30
const C_DIV: i32 = 100 / 2; // 50

// 3. Bitwise Operations (Essential for UART/Drivers)
const C_AND: u32 = 0xF0 & 0x0F; // 0
const C_OR: u32 = 0xF0 | 0x0F;  // 240 (0xFF)
const C_XOR: u32 = 0xAA ^ 0x55; // 255 (0xFF)
const C_SHL: u32 = 1 << 4;      // 16
const C_SHR: u32 = 16 >> 2;     // 4
const C_NOT: u32 = !0;          // -1 (if signed) or 0xFFFFFFFF (if unsigned)
                                // In evaluator it's !i64. !0 -> -1.

// 4. Reference to other constants
const C_REF_1: i32 = C_INT; // 100
const C_REF_2: i32 = C_INT + 5; // 105
const UART_REG: u32 = 0x3F8 + 1; // 0x3F9 (1017)

// 5. Logic
const L_NOT: bool = !false; // true
const L_AND: bool = true && false; // false
const L_OR: bool = false || true;  // true

// 6. Type variety
const C_U8: u8 = 255;
const C_I64: i64 = -123456789;

fn main() -> i32 {
    let mut failures = 0;

    // Check Basic & Hex
    if C_INT != 100 { failures = failures + 1; }
    if C_HEX != 1016 { failures = failures + 1; }
    if C_FLOAT < 1.4 || C_FLOAT > 1.6 { failures = failures + 1; }
    if !C_BOOL { failures = failures + 1; }

    // Check Arithmetic
    if C_ADD != 30 { failures = failures + 1; }
    if C_SUB != 50 { failures = failures + 1; }
    if C_MUL != 30 { failures = failures + 1; }
    if C_DIV != 50 { failures = failures + 1; }
    
    // Check Bitwise
    if C_AND != 0 { failures = failures + 1; }
    if C_OR != 240 { failures = failures + 1; }
    if C_XOR != 255 { failures = failures + 1; }
    if C_SHL != 16 { failures = failures + 1; }
    if C_SHR != 4 { failures = failures + 1; }
    
    // Check References
    if C_REF_1 != 100 { failures = failures + 1; }
    if C_REF_2 != 105 { failures = failures + 1; }
    if UART_REG != 1017 { failures = failures + 1; }
    
    // Check Logic
    if !L_NOT { failures = failures + 1; }
    if L_AND { failures = failures + 1; }
    if !L_OR { failures = failures + 1; }
    
    // Check Shadowing (Symbol Precedence)
    // const C_INT is 100.
    let C_INT = 999;
    if C_INT != 999 { failures = failures + 1; } // Local should win
    
    return failures;
}
