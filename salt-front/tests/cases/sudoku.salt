extern fn rdtsc() -> i64;
struct Board { cells: [u8; 81] }

fn is_valid(b: &Board, r: i32, c: i32, n: u8) -> bool {
    for i in 0..9 {
        if b.cells[(r * 9 + i) as usize] == n || b.cells[(i * 9 + c) as usize] == n { return false; }
    }
    let (sr, sc) = ((r / 3) * 3, (c / 3) * 3);
    for i in 0..3 {
        for j in 0..3 {
            if b.cells[((sr + i) * 9 + (sc + j)) as usize] == n { return false; }
        }
    }
    return true;
}

fn solve(b: &mut Board) -> Status {
    for i in 0..81 {
        if b.cells[i] == 0 {
            for n in 1..10 {
                if is_valid(b, (i / 9) as i32, (i % 9) as i32, n as u8) {
                    b.cells[i] = n as u8;
                    solve(b)?; 
                    b.cells[i] = 0;
                }
            }
            return Status::Unsolvable; // Explicit Failure
        }
    }
    return Status::Found; // Explicit Success
}

fn main() -> i32 {
    let mut board = Board { cells: [0; 81] };
    for idx in 0..81 {
        let (r, c) = ((idx / 9) as i32, (idx % 9) as i32);
        board.cells[idx] = ((((r % 3) * 3 + (r / 3) + c) % 9) + 1) as u8;
    }
    board.cells[72] = 0; board.cells[73] = 0; board.cells[74] = 0;

    let start = rdtsc();
    if solve(&mut board) == Status::Found {
        println(f"Solved! Cycles: {rdtsc() - start}");
    } else {
        println("No solution.");
    }
    return 0;
}
