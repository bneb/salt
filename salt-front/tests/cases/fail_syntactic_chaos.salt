fn main() -> i32 {
    // 1. Array Repeat (Ok path)
    let arr: [i32; 1] = [1; 1];

    // 2. Expressions that should hit the `_ => "unsupported"` catch-all
    // These are valid Rust statements (syn parses them), but Salt codegen doesn't support them.
    // They should compile (emit "unsupported" MLIR) and not panic.

    // Async block
    async { 1 };

    // Closure
    |x: i32| x;

    // Tuple
    (1, 2);

    // Range
    1..2;

    // Try operator
    // (1?); // syntax might be tricky without Result context? strict parse?
    // Let's stick to sure things.

    // Match statement (as expression)
    match 1 { _ => 1 };

    // 3. Assign to Call (Invalid L-Value)
    // This triggers explicit Err in codegen. 
    // Commented out because getting the compiler to return Err stops the test runner (which expects success or specific failure).
    // But for coverage we want to HIT the line. 
    // The runner 'tests/runner.rs' likely checks that compilation succeeds.
    // If we want to test compilation FAILURE, we need a separate test file or move this to 'syntactic_chaos_fail.salt'.
    // The user instruction said "Target emit_addr error paths".
    // I created 'syntactic_chaos_cast.salt' and '_unary.salt' for that.
    // I should create 'syntactic_chaos_assign_call.salt' too.
    
    return 0;
}
