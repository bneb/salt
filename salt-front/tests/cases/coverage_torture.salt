
// Coverage Torture Test Suite
// Designed to exercise rare code paths in `expr/mod.rs` and `stmt/mod.rs`

struct PaddingTest {
    a: i8,
    b: i64, // Force 7 bytes padding
    c: i8,
    d: i16  // Force 1 byte padding after c
}

// Deeply nested generic struct to stress monomorphization and layout cache
struct DeepNest<T> {
    val: T,
    next: Owned<DeepNest<T>>
}

struct MyTortureStruct {
    a: i32
}

// ==========================================
// 2. Exhaustive Pattern Matching
// ==========================================
enum ComplexEnum {
    A(i32),
    B(i32),
    C(f32),
    D,
    E
}

fn test_match(e: ComplexEnum) -> i32 {
    return match e {
        ComplexEnum::A(val) => val,
        ComplexEnum::B(val) => val,
        ComplexEnum::C(x) => x as i32,
        ComplexEnum::D => 42,
        ComplexEnum::E => -1
    };
}

// ==========================================
// 3. Complex Numeric Conversions
// ==========================================
fn test_casts() -> i32 {
    let a: i8 = -10;
    let b: u8 = 200;
    let c: f32 = 3.14;
    
    // Signed/Unsigned Widening/Narrowing permutations
    let d: i64 = a as i64; // Sign extend
    let e: u64 = b as u64; // Zero extend
    let f: i32 = b as i32; // u8 -> i32
    
    // Float/Int conversions
    let g: f64 = c as f64; // Float ext
    let h: i32 = c as i32; // f32 -> i32 (trunc)
    let i: f32 = a as f32; // i8 -> f32
    let j: u8 = c as u8;   // f32 -> u8
    
    return (d as i32) + f + h + (j as i32);
}

// ==========================================
// 4. Control Flow Torture
// ==========================================
fn test_nested_loops() -> i32 {
    let mut sum = 0;
    let mut i = 0;
    while i < 5 {
        let mut j = 0;
        while j < 5 {
            let mut k = 0;
            while k < 5 {
                if k == 2 {
                    k = k + 1;
                    continue;
                }
                if i + j + k > 10 {
                    break;
                }
                sum = sum + 1;
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return sum;
}

fn test_early_return_chain(x: i32) -> i32 {
    if x == 1 { return 10; }
    if x == 2 { return 20; }
    if x == 3 { return 30; }
    if x == 4 { return 40; }
    if x == 5 { return 50; }
    if x == 6 { return 60; }
    if x == 7 { return 70; }
    if x == 8 { return 80; }
    if x == 9 { return 90; }
    if x == 10 { return 100; }
    
    let mut res = 0;
    if x > 100 {
        res = 1000;
    } else {
        res = 500;
    }
    return res;
}

fn test_cfg(limit: i32) -> i32 {
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    
    // While loop with internal complexity
    while i < limit {
        if i % 2 == 0 {
            // Continue inside if
            i = i + 1;
            continue;
        }
        
        if i == 7 {
             // Break inside if
             break;
        }
        
        // Nested loop
        let mut j: i32 = 0;
        while true {
            if j > 3 { break; }
            sum = sum + j;
            j = j + 1;
        }
        
        sum = sum + i;
        i = i + 1;
    }
    
    // Repeat loop (if supported grammar, else loop)
    // Testing "break with value" semantics if Salt supports it? 
    // Assuming standard loop break for now.
    
    return sum;
}

// ==========================================
// 5. Rarest Expression Paths
// ==========================================
fn test_expr_torture() -> i32 {
    // Chained logicals with mixed types/calls
    let x = (test_casts() > 0) && (test_cfg(10) < 100) || false;
    
    // Tuple access in complex expr
    let t = (1, 2, 3);
    let y = t.0 + (t.1 * t.2);
    
    // Array access with complex index
    let arr = [10, 20, 30, 40];
    let z = arr[(t.0 + 1) as usize];
    
    // Block expression returning value
    let w = {
        let tmp = 10;
        tmp * 2
    };
    
    return if x { y + z + w } else { 0 };
}


fn test_permutations() -> i32 {
    let mut sum: i32 = 0;
    // Initialize variables
    let val_i8: i8 = 1;
    let val_u8: u8 = 1;
    let val_i16: i16 = 1;
    let val_u16: u16 = 1;
    let val_i32: i32 = 1;
    let val_u32: u32 = 1;
    let val_i64: i64 = 1;
    let val_u64: u64 = 1;
    let val_f32: f32 = 1.0;
    let val_f64: f64 = 1.0;

    // Permutations
    sum = sum + (val_i8 as u8) as i32;
    sum = sum + (val_i8 as i16) as i32;
    sum = sum + (val_i8 as u16) as i32;
    sum = sum + (val_i8 as i32) as i32;
    sum = sum + (val_i8 as u32) as i32;
    sum = sum + (val_i8 as i64) as i32;
    sum = sum + (val_i8 as u64) as i32;
    sum = sum + (val_i8 as f32) as i32;
    sum = sum + (val_i8 as f64) as i32;
    sum = sum + (val_u8 as i8) as i32;
    sum = sum + (val_u8 as i16) as i32;
    sum = sum + (val_u8 as u16) as i32;
    sum = sum + (val_u8 as i32) as i32;
    sum = sum + (val_u8 as u32) as i32;
    sum = sum + (val_u8 as i64) as i32;
    sum = sum + (val_u8 as u64) as i32;
    sum = sum + (val_u8 as f32) as i32;
    sum = sum + (val_u8 as f64) as i32;
    sum = sum + (val_i16 as i8) as i32;
    sum = sum + (val_i16 as u8) as i32;
    sum = sum + (val_i16 as u16) as i32;
    sum = sum + (val_i16 as i32) as i32;
    sum = sum + (val_i16 as u32) as i32;
    sum = sum + (val_i16 as i64) as i32;
    sum = sum + (val_i16 as u64) as i32;
    // sum = sum + (val_i16 as f32) as i32;
    // sum = sum + (val_i16 as f64) as i32;
    sum = sum + (val_u16 as i8) as i32;
    sum = sum + (val_u16 as u8) as i32;
    sum = sum + (val_u16 as i16) as i32;
    sum = sum + (val_u16 as i32) as i32;
    sum = sum + (val_u16 as u32) as i32;
    sum = sum + (val_u16 as i64) as i32;
    sum = sum + (val_u16 as u64) as i32;
    // sum = sum + (val_u16 as f32) as i32;
    // sum = sum + (val_u16 as f64) as i32;
    sum = sum + (val_i32 as i8) as i32;
    sum = sum + (val_i32 as u8) as i32;
    sum = sum + (val_i32 as i16) as i32;
    sum = sum + (val_i32 as u16) as i32;
    sum = sum + (val_i32 as u32) as i32;
    sum = sum + (val_i32 as i64) as i32;
    sum = sum + (val_i32 as u64) as i32;
    sum = sum + (val_i32 as f32) as i32;
    sum = sum + (val_i32 as f64) as i32;
    sum = sum + (val_u32 as i8) as i32;
    sum = sum + (val_u32 as u8) as i32;
    sum = sum + (val_u32 as i16) as i32;
    sum = sum + (val_u32 as u16) as i32;
    sum = sum + (val_u32 as i32) as i32;
    sum = sum + (val_u32 as i64) as i32;
    sum = sum + (val_u32 as u64) as i32;
    sum = sum + (val_u32 as f32) as i32;
    sum = sum + (val_u32 as f64) as i32;
    sum = sum + (val_i64 as i8) as i32;
    sum = sum + (val_i64 as u8) as i32;
    sum = sum + (val_i64 as i16) as i32;
    sum = sum + (val_i64 as u16) as i32;
    sum = sum + (val_i64 as i32) as i32;
    sum = sum + (val_i64 as u32) as i32;
    sum = sum + (val_i64 as u64) as i32;
    sum = sum + (val_i64 as f32) as i32;
    sum = sum + (val_i64 as f64) as i32;
    sum = sum + (val_u64 as i8) as i32;
    sum = sum + (val_u64 as u8) as i32;
    sum = sum + (val_u64 as i16) as i32;
    sum = sum + (val_u64 as u16) as i32;
    sum = sum + (val_u64 as i32) as i32;
    sum = sum + (val_u64 as u32) as i32;
    sum = sum + (val_u64 as i64) as i32;
    sum = sum + (val_u64 as f32) as i32;
    sum = sum + (val_u64 as f64) as i32;
    sum = sum + (val_f32 as i8) as i32;
    sum = sum + (val_f32 as u8) as i32;
    // sum = sum + (val_f32 as i16) as i32;
    // sum = sum + (val_f32 as u16) as i32;
    sum = sum + (val_f32 as i32) as i32;
    sum = sum + (val_f32 as u32) as i32;
    sum = sum + (val_f32 as i64) as i32;
    sum = sum + (val_f32 as u64) as i32;
    sum = sum + (val_f32 as f64) as i32;
    sum = sum + (val_f64 as i8) as i32;
    sum = sum + (val_f64 as u8) as i32;
    // sum = sum + (val_f64 as i16) as i32;
    // sum = sum + (val_f64 as u16) as i32;
    sum = sum + (val_f64 as i32) as i32;
    sum = sum + (val_f64 as u32) as i32;
    sum = sum + (val_f64 as i64) as i32;
    sum = sum + (val_f64 as u64) as i32;
    sum = sum + (val_f64 as f32) as i32;
    return sum;
}

public fn main() -> i32 {
    let m = test_match(ComplexEnum::A(10));
    let c = test_casts();
    let cfg = test_cfg(20);
    let expr = test_expr_torture();
    let perms = test_permutations();
    
    return m + c + cfg + expr + perms;
}
