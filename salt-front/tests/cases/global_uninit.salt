// salt-front/tests/cases/global_uninit.salt

struct Point {
    x: i64,
    y: i64
}

enum State {
    Idle,
    Active(i32)
}

global G_I8: i8;
global G_I32: i32;
global G_I64: i64;
global G_U8: u8;
global G_U32: u32;
global G_U64: u64;
global G_Usize: usize;
global G_F32: f32;
global G_F64: f64;
global G_BOOL: bool;
global G_OWNED: Owned<i32>;
global G_REF: &i32;
global G_ATOMIC: Atomic<i32>;
global G_ARRAY: [i32; 2];
global G_TUPLE: (i32, f64);
global G_STRUCT: Point;
global G_ENUM: State;

pub fn main() -> i32 {
    // Only load non-linear types to avoid leak checks in this test
    let a = G_I8;
    let b = G_I32;
    let c = G_I64;
    let d = G_U8;
    let e = G_U32;
    let f = G_U64;
    let g = G_Usize;
    let h = G_F32;
    let i = G_F64;
    let j = G_BOOL;
    let l = G_REF;
    let n = G_ARRAY;
    let o = G_TUPLE;
    let p = G_STRUCT;
    // G_OWNED, G_ATOMIC, G_ENUM are kept as globals but not loaded here
    return 0;
}
