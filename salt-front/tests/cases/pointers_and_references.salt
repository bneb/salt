fn take_ref(x: &i32) -> i32 {
    return *x;
}

fn take_mut_ref(x: &mut i32) {
    *x = *x + 1;
}

struct Node {
    val: i32,
}

fn take_owned(n: Owned<Node>) -> i32 {
    let v = n.val;
    move n; // explicit consume (no parens)
    return v;
}

fn main() {
    let mut val = 10;
    let r = &val;
    let _ = take_ref(r);
    
    let mr = &mut val;
    take_mut_ref(mr);
    
    let n = Node { val: 20 };
    let _ = take_owned(n);
}
