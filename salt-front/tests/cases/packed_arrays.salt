package tests.packed_arrays

struct Sieve {
    @packed
    primes: [bool; 100]
}

// Test basic read/write
fn test_packed_basic() -> i32 {
    let mut s = Sieve { primes: [false; 100] }; 
    // This triggers promote_numeric (Unpacked -> Packed)

    s.primes[0] = true;
    s.primes[10] = true;
    s.primes[63] = true; // Last bit of first word
    s.primes[64] = true; // First bit of second word
    
    if !s.primes[0] { return 1; }
    if !s.primes[10] { return 2; }
    if !s.primes[63] { return 3; }
    if !s.primes[64] { return 4; }
    if s.primes[1] { return 100; } // Check false-negatives
    
    // Toggle
    s.primes[10] = !s.primes[10];
    if s.primes[10] { return 5; } // Should be false now
    
    s.primes[10] = true;
    if !s.primes[10] { return 6; }
    
    return 0;
}

// Test compound assignment
fn test_compound() -> i32 {
    let mut s = Sieve { primes: [false; 100] };
    s.primes[5] = true;
    
    // Toggle with XOR
    s.primes[5] ^= true;
    if s.primes[5] { return 10; }
    
    s.primes[5] ^= true;
    if !s.primes[5] { return 11; }
    
    // OR
    s.primes[70] |= true;
    if !s.primes[70] { return 12; }
    
    // AND
    s.primes[70] &= false;
    if s.primes[70] { return 13; }
    
    return 0;
}

fn main() -> i32 {
    if test_packed_basic() != 0 { return test_packed_basic(); }
    if test_compound() != 0 { return test_compound(); }
    return 0;
}
