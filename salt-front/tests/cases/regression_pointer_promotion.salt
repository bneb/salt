struct Point { x: i32, y: i32 }

fn main() -> i32 {
    let mut p: Owned<Point> = reinterpret_cast::<Point>(1000usize);
    
    // This requires Promotion: Reference<Point> -> Owned<Point> (or vice versa, 
    // depending on what promote_numeric handles for pointer decay/bitcast)
    // Actually, in window_access it was Window -> Window with different params.
    
    let ptr: i64 = reinterpret_cast::<i64>(p);
    if ptr == 1000 {
        return 0;
    }
    return 1;
}
