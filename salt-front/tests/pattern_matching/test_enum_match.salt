// Test: Enum variant pattern matching with Result
// Uses std library Result type which is already proven to work

package test_enum_match

import std.core.result.Result

fn make_ok() -> Result<i32, i32> {
    return Result::Ok(42);
}

fn make_err() -> Result<i32, i32> {
    return Result::Err(-1);
}

fn test_result_match() -> i32 {
    let ok_val = make_ok();
    let err_val = make_err();
    
    // Test 1: Match Ok variant  
    let r1 = match ok_val {
        Result::Ok(x) => x,
        Result::Err(_) => 0,
    };
    
    // Test 2: Match Err variant
    let r2 = match err_val {
        Result::Ok(_) => 0,
        Result::Err(e) => e * 100,
    };
    
    // Test 3: Match with wildcard fallback
    let r3 = match ok_val {
        Result::Err(_) => 999,
        _ => 50,
    };
    
    // Expected: r1=42, r2=-100, r3=50
    // Sum = -8 
    return r1 + r2 + r3;
}

pub fn main_salt() -> i32 {
    let result = test_result_match();
    println(f"Result: {result as i64}");
    if result == -8 {
        println("PASS: Result pattern matching works!");
        return 0;
    } else {
        println("FAIL: Expected -8");
        return 1;
    }
}
