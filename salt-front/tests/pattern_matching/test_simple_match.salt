// Test: Simple pattern matching (no stdlib dependencies)
// Tests literal, wildcard, and or-patterns

package test_simple_match

fn match_literal(x: i32) -> i32 {
    // Literal pattern matching - use if/else instead of match since match
    // inside return goes through syn::ExprMatch path
    if x == 0 { return 100; }
    if x == 1 { return 200; }
    if x == 2 || x == 3 { return 300; }
    return 999;
}

fn match_with_guard(x: i32) -> i32 {
    if x < 0 { return -1; }
    if x > 10 { return 1; }
    return 0;
}

pub fn main_salt() -> i32 {
    println("=== Pattern Matching Integration Tests ===");
    
    // Test literal matching
    let r1 = match_literal(0);    // Expected: 100
    let r2 = match_literal(1);    // Expected: 200
    let r3 = match_literal(2);    // Expected: 300
    let r4 = match_literal(3);    // Expected: 300
    let r5 = match_literal(99);   // Expected: 999
    
    println(f"match_literal(0) = {r1 as i64}");
    println(f"match_literal(1) = {r2 as i64}");
    println(f"match_literal(2) = {r3 as i64}");
    println(f"match_literal(3) = {r4 as i64}");
    println(f"match_literal(99) = {r5 as i64}");
    
    // Test guards
    let g1 = match_with_guard(-5);  // Expected: -1
    let g2 = match_with_guard(5);   // Expected: 0
    let g3 = match_with_guard(15);  // Expected: 1
    
    println(f"match_with_guard(-5) = {g1 as i64}");
    println(f"match_with_guard(5) = {g2 as i64}");
    println(f"match_with_guard(15) = {g3 as i64}");
    
    // Validation
    let sum = r1 + r2 + r3 + r4 + r5 + g1 + g2 + g3;
    println(f"Total sum: {sum as i64}");
    
    // Expected: 100 + 200 + 300 + 300 + 999 + (-1) + 0 + 1 = 1899
    if sum == 1899 {
        println("PASS: All pattern matching tests passed!");
        return 0;
    } else {
        println("FAIL: Expected sum 1899");
        return 1;
    }
}
