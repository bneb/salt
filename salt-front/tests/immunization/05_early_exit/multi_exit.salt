// Multiple Exit Points Test
// Multiple return statements from different branches

fn classify(x: i32) -> i32 {
    if x < 0 {
        return -1;  // Exit point 1
    }
    
    let mut i: i32 = 0;
    while i < x {
        if i > 10 {
            return 1;  // Exit point 2 (from loop)
        }
        i = i + 1;
    }
    
    if x == 0 {
        return 0;  // Exit point 3
    }
    
    return 2;  // Exit point 4 (fallthrough)
}

fn nested_exits(a: i32, b: i32) -> i32 {
    let mut result: i32 = 0;
    let mut i: i32 = 0;
    
    while i < a {
        let mut j: i32 = 0;
        while j < b {
            result = result + 1;
            
            if result > 15 {
                return result;  // Exit from inner loop
            }
            j = j + 1;
        }
        
        if result > 10 {
            return result + 100;  // Exit from outer loop
        }
        i = i + 1;
    }
    
    return result;
}

pub fn main(argc: i32) -> i32 {
    // Test classify function with different paths
    if classify(-5) == -1 {
        println("PASS: negative -> -1");
    } else {
        return 1;
    }
    
    if classify(0) == 0 {
        println("PASS: zero -> 0");
    } else {
        return 2;
    }
    
    if classify(5) == 2 {
        println("PASS: small positive -> 2");
    } else {
        return 3;
    }
    
    if classify(20) == 1 {
        println("PASS: large positive -> 1");
    } else {
        return 4;
    }
    
    // Test nested exits
    let r1 = nested_exits(3, 4);  // 3*4 = 12 > 10, returns 112
    if r1 == 112 {
        println("PASS: nested 3x4 = 112");
    } else {
        println(f"FAIL: nested 3x4 = {r1 as i64}");
        return 5;
    }
    
    let r2 = nested_exits(5, 5);  // 16 > 15, returns 16
    if r2 == 16 {
        println("PASS: nested 5x5 = 16");
    } else {
        println(f"FAIL: nested 5x5 = {r2 as i64}");
        return 6;
    }
    
    println("All multi-exit tests passed!");
    return 0;
}
