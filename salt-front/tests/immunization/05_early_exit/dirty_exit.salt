// Dirty Exit Test
// A mut variable is updated inside the loop, then returned
// Tests that Phi-nodes correctly select the latest version

fn accumulate_and_exit(limit: i32) -> i32 {
    let mut accumulator: i32 = 0;
    let mut i: i32 = 0;
    
    while i < 100 {
        accumulator = accumulator + i;  // Update mut variable
        
        if accumulator >= limit {
            return accumulator;  // Return the UPDATED value
        }
        i = i + 1;
    }
    
    return accumulator;
}

fn modify_multiple(n: i32) -> i32 {
    let mut a: i32 = 0;
    let mut b: i32 = 0;
    let mut i: i32 = 0;
    
    while i < n {
        a = a + 1;
        b = b + 2;
        
        if a > 5 {
            // Return expression using BOTH updated variables
            return a + b;
        }
        i = i + 1;
    }
    
    return a * b;
}

pub fn main(argc: i32) -> i32 {
    // Test 1: Accumulator exits at threshold
    let result1 = accumulate_and_exit(50);
    // 0+1+2+...+9 = 45, +10 = 55 >= 50, so should return 55
    if result1 == 55 {
        println("PASS: accumulator = 55");
    } else {
        println(f"FAIL: accumulator = {result1 as i64}");
        return 1;
    }
    
    // Test 2: Multiple mutable variables
    let result2 = modify_multiple(10);
    // When a > 5 (a=6), b = 12, so return 6+12 = 18
    if result2 == 18 {
        println("PASS: a+b = 18");
    } else {
        println(f"FAIL: a+b = {result2 as i64}");
        return 2;
    }
    
    // Test 3: Exit at first iteration
    let result3 = accumulate_and_exit(0);
    // accumulator starts at 0, 0 >= 0, return immediately
    if result3 == 0 {
        println("PASS: immediate exit returns 0");
    } else {
        println(f"FAIL: immediate exit = {result3 as i64}");
        return 3;
    }
    
    println("All dirty exit tests passed!");
    return 0;
}
