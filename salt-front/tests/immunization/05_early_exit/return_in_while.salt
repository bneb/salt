// Return Inside While Test
// Test Phi-node cleanup when returning from inside a loop

fn find_first_even(start: i32, max: i32) -> i32 {
    let mut i: i32 = start;
    while i < max {
        if (i % 2) == 0 {
            return i;  // Early exit with return
        }
        i = i + 1;
    }
    return -1;  // Not found
}

fn count_until(target: i32) -> i32 {
    let mut count: i32 = 0;
    let mut i: i32 = 0;
    while i < 100 {
        count = count + 1;
        if i == target {
            return count;  // Return the count when we hit target
        }
        i = i + 1;
    }
    return count;
}

pub fn main(argc: i32) -> i32 {
    // Test 1: Find first even starting from odd
    let result1 = find_first_even(5, 20);
    if result1 == 6 {
        println("PASS: first even after 5 is 6");
    } else {
        println(f"FAIL: got {result1 as i64}, expected 6");
        return 1;
    }
    
    // Test 2: Find first even starting from even
    let result2 = find_first_even(10, 20);
    if result2 == 10 {
        println("PASS: first even after 10 is 10");
    } else {
        println(f"FAIL: got {result2 as i64}, expected 10");
        return 2;
    }
    
    // Test 3: Not found case
    let result3 = find_first_even(21, 21);
    if result3 == -1 {
        println("PASS: not found returns -1");
    } else {
        println(f"FAIL: got {result3 as i64}, expected -1");
        return 3;
    }
    
    // Test 4: Count until target
    let count = count_until(5);
    if count == 6 {  // 0,1,2,3,4,5 = 6 iterations
        println("PASS: counted 6 iterations to reach 5");
    } else {
        println(f"FAIL: count = {count as i64}, expected 6");
        return 4;
    }
    
    println("All return-in-while tests passed!");
    return 0;
}
