// Pointer Comparison Inside Loop Test
// The LRU Cache pattern: null check inside while loop body
// This is the exact pattern that caused infinite loops before the fix

extern fn malloc_shim(size: usize) -> !llvm.ptr;

pub fn main(argc: i32) -> i32 {
    // Create an array of pointers (some null, some not)
    let arr = malloc_shim(8 * 10);  // 10 pointers
    
    // Initialize: first 5 are null, next 5 are valid
    let mut i: usize = 0;
    while i < 5 {
        *((arr as i64 + (i * 8) as i64) as !llvm.ptr as &mut !llvm.ptr) = 0 as !llvm.ptr;
        i = i + 1;
    }
    while i < 10 {
        *((arr as i64 + (i * 8) as i64) as !llvm.ptr as &mut !llvm.ptr) = malloc_shim(8);
        i = i + 1;
    }
    
    // Count null pointers using loop with null check
    let mut null_count: usize = 0;
    let mut j: usize = 0;
    while j < 10 {
        let ptr = *((arr as i64 + (j * 8) as i64) as !llvm.ptr as &!llvm.ptr);
        if ptr == (0 as !llvm.ptr) {
            null_count = null_count + 1;
        }
        j = j + 1;
    }
    
    if null_count == 5 {
        println(f"PASS: Found correct number of null pointers ({null_count as i64})");
    } else {
        println(f"FAIL: Expected 5 nulls, found {null_count as i64}");
        return 1;
    }
    
    // Hash-table style probing pattern (the actual LRU bug pattern)
    let map_size: usize = 8;
    let map = malloc_shim(8 * map_size);
    
    // Zero-init the map
    let mut k: usize = 0;
    while k < map_size {
        *((map as i64 + (k * 8) as i64) as !llvm.ptr as &mut !llvm.ptr) = 0 as !llvm.ptr;
        k = k + 1;
    }
    
    // Linear probe to find empty slot
    let mut probe_idx: usize = 3;  // Start at index 3
    let mut probe_count: usize = 0;
    while probe_count < map_size {
        let slot = *((map as i64 + (probe_idx * 8) as i64) as !llvm.ptr as &!llvm.ptr);
        if slot == (0 as !llvm.ptr) {
            println(f"PASS: Found empty slot at index {probe_idx as i64}");
            probe_count = map_size;  // Exit
        } else {
            probe_idx = (probe_idx + 1) % map_size;
            probe_count = probe_count + 1;
        }
    }
    
    println("All loop pointer tests passed!");
    return 0;
}
