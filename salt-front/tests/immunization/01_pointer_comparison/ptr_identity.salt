// Pointer Identity vs Content Test
// CRITICAL: ptr1 == ptr2 must compare ADDRESSES, not dereferenced VALUES
// Two pointers to same value at different addresses must compare NOT equal

extern fn malloc_shim(size: usize) -> !llvm.ptr;

pub fn main(argc: i32) -> i32 {
    // Allocate two separate memory locations
    let ptr1 = malloc_shim(8);
    let ptr2 = malloc_shim(8);
    
    // Store the same value (42) at both locations
    *(ptr1 as &mut i64) = 42;
    *(ptr2 as &mut i64) = 42;
    
    // Test 1: Different addresses with same value must compare NOT equal
    if ptr1 == ptr2 {
        println("FAIL: Different addresses compared equal!");
        return 1;
    } else {
        println("PASS: Different addresses are not equal");
    }
    
    // Test 2: Same address must compare equal
    let ptr3 = ptr1;  // Copy the address
    if ptr1 == ptr3 {
        println("PASS: Same address compares equal");
    } else {
        println("FAIL: Same address did not compare equal");
        return 2;
    }
    
    // Test 3: Verify the VALUES are the same (to prove test validity)
    let val1 = *(ptr1 as &i64);
    let val2 = *(ptr2 as &i64);
    if val1 == val2 {
        println("PASS: Values at different addresses are equal");
    } else {
        println("FAIL: Values should be equal");
        return 3;
    }
    
    println("All identity tests passed!");
    return 0;
}
