// Immunization: Struct vs Value Equality
// This test ensures that comparing a single-field struct (like Status)
// results in a member-wise comparison (value comparison) 
// instead of a pointer comparison (which would always be false for separate instances).

struct Status {
    code: i32,
}

struct Point {
    x: i32,
    y: i32,
}

fn make_status(c: i32) -> Status {
    return Status { code: c };
}

pub fn main() -> i32 {
    let s1 = Status { code: 200 };
    let s2 = make_status(200);
    
    // Value comparison should be true
    if s1 == s2 {
        println("PASS: Status value equality");
    } else {
        println("FAIL: Status value equality (pointer comparison detected?)");
        return 1;
    }

    let s3 = Status { code: 404 };
    if s1 != s3 {
        println("PASS: Status value inequality");
    } else {
        println("FAIL: Status value inequality");
        return 2;
    }

    // Multi-field struct equality
    let p1 = Point { x: 10, y: 20 };
    let p2 = Point { x: 10, y: 20 };
    if p1 == p2 {
        println("PASS: Point value equality");
    } else {
        println("FAIL: Point value equality");
        return 3;
    }

    let p3 = Point { x: 10, y: 21 };
    if p1 != p3 {
        println("PASS: Point value inequality");
    } else {
        println("FAIL: Point value inequality");
        return 4;
    }

    return 0;
}

