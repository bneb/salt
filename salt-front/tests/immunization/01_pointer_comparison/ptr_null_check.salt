// Pointer Null Check Test
// CRITICAL: ptr == null must compare ADDRESSES, not dereference values
// Bug Fixed: codegen.rs lines 1736-1760 now skips auto-deref for Eq/Ne on pointers

extern fn malloc_shim(size: usize) -> !llvm.ptr;

pub fn main(argc: i32) -> i32 {
    // Test 1: Null literal comparison
    let null_ptr: !llvm.ptr = 0 as !llvm.ptr;
    if null_ptr == (0 as !llvm.ptr) {
        println("PASS: null == null");
    } else {
        println("FAIL: null != null");
        return 1;
    }
    
    // Test 2: Non-null check
    let valid_ptr = malloc_shim(8);
    if valid_ptr != (0 as !llvm.ptr) {
        println("PASS: malloc != null");
    } else {
        println("FAIL: malloc == null");
        return 2;
    }
    
    // Test 3: Variable-to-variable null comparison
    let also_null: !llvm.ptr = 0 as !llvm.ptr;
    if null_ptr == also_null {
        println("PASS: null_var == null_var");
    } else {
        println("FAIL: null_var != null_var");
        return 3;
    }
    
    // Test 4: Null != non-null
    if null_ptr != valid_ptr {
        println("PASS: null != valid");
    } else {
        println("FAIL: null == valid");
        return 4;
    }
    
    println("All null check tests passed!");
    return 0;
}
