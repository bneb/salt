// Sign Extension Chain Test
// CRITICAL: i8 → i32 → i64 must preserve sign (negative values stay negative)
// Security bug if -1i8 becomes 255 after promotion!

pub fn main(argc: i32) -> i32 {
    // Test 1: Positive i8 → i32
    let pos8: i8 = 100;
    let pos32: i32 = pos8 as i32;
    if pos32 == 100 {
        println("PASS: 100i8 → 100i32");
    } else {
        println(f"FAIL: 100i8 promotion failed, got {pos32 as i64}");
        return 1;
    }
    
    // Test 2: Negative i8 → i32 (CRITICAL)
    let neg8: i8 = -50;
    let neg32: i32 = neg8 as i32;
    if neg32 == -50 {
        println("PASS: -50i8 → -50i32");
    } else {
        println(f"FAIL: -50i8 became {neg32 as i64} (should be -50)");
        return 2;
    }
    
    // Test 3: i32 → i64
    let val32: i32 = -1000;
    let val64: i64 = val32 as i64;
    if val64 == -1000 {
        println("PASS: -1000i32 → -1000i64");
    } else {
        println(f"FAIL: -1000i32 became {val64}");
        return 3;
    }
    
    // Test 4: Full chain i8 → i32 → i64
    let tiny: i8 = -1;
    let mid: i32 = tiny as i32;
    let big: i64 = mid as i64;
    if big == -1 {
        println("PASS: -1i8 → -1i32 → -1i64");
    } else {
        println(f"FAIL: -1i8 chain became {big} (should be -1)");
        return 4;
    }
    
    println("All sign extension tests passed!");
    return 0;
}
