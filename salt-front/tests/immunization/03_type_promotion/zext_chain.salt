// Zero Extension Chain Test
// u8 → u32 → u64 must pad with zeros (255 stays 255, not sign-extended to -1)

pub fn main(argc: i32) -> i32 {
    // Test 1: u8 → u32
    let byte: u8 = 200;
    let word: u32 = byte as u32;
    if word == 200 {
        println("PASS: 200u8 → 200u32");
    } else {
        println(f"FAIL: 200u8 became {word as i64}");
        return 1;
    }
    
    // Test 2: u8 max value → u32
    let max8: u8 = 255;
    let max32: u32 = max8 as u32;
    if max32 == 255 {
        println("PASS: 255u8 → 255u32");
    } else {
        println(f"FAIL: 255u8 became {max32 as i64} (sign-extended?)");
        return 2;
    }
    
    // Test 3: u32 → u64
    let val32: u32 = 4000000000;  // Near u32 max
    let val64: u64 = val32 as u64;
    if val64 == 4000000000 {
        println("PASS: 4B u32 → 4B u64");
    } else {
        println(f"FAIL: 4B u32 became {val64 as i64}");
        return 3;
    }
    
    // Test 4: Full chain u8 → u32 → u64
    let tiny: u8 = 255;
    let mid: u32 = tiny as u32;
    let big: u64 = mid as u64;
    if big == 255 {
        println("PASS: 255u8 → 255u32 → 255u64");
    } else {
        println(f"FAIL: 255u8 chain became {big as i64}");
        return 4;
    }
    
    println("All zero extension tests passed!");
    return 0;
}
