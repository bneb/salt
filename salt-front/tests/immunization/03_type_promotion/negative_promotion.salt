// Negative Promotion Test
// CRITICAL SECURITY TEST: -1i8 to i64 MUST remain -1, not become 255!
// This is where bounds-check bypasses are born.

pub fn main(argc: i32) -> i32 {
    // The critical test: -1i8 must stay -1 through all promotions
    let minus_one_i8: i8 = -1;
    let minus_one_i64: i64 = minus_one_i8 as i64;
    
    if minus_one_i64 == -1 {
        println("PASS: -1i8 → -1i64");
    } else {
        println(f"CRITICAL FAIL: -1i8 became {minus_one_i64} (expected -1)");
        // This is a security vulnerability if it fails
        return 1;
    }
    
    // Test boundary values
    let min_i8: i8 = -128;  // i8 minimum
    let min_i64: i64 = min_i8 as i64;
    if min_i64 == -128 {
        println("PASS: -128i8 → -128i64");
    } else {
        println(f"FAIL: -128i8 became {min_i64}");
        return 2;
    }
    
    let max_i8: i8 = 127;  // i8 maximum
    let max_i64: i64 = max_i8 as i64;
    if max_i64 == 127 {
        println("PASS: 127i8 → 127i64");
    } else {
        println(f"FAIL: 127i8 became {max_i64}");
        return 3;
    }
    
    // Test i8 used in comparison after promotion
    let threshold: i64 = 0;
    if minus_one_i64 < threshold {
        println("PASS: promoted -1 is less than 0");
    } else {
        println("CRITICAL FAIL: promoted -1 >= 0 (bounds check bypass!)");
        return 4;
    }
    
    // Test in arithmetic
    let base: i64 = 1000;
    let offset_i8: i8 = -10;
    let result = base + (offset_i8 as i64);
    if result == 990 {
        println("PASS: 1000 + (-10i8) = 990");
    } else {
        println(f"FAIL: 1000 + (-10i8) = {result} (expected 990)");
        return 5;
    }
    
    println("All negative promotion tests passed!");
    return 0;
}
