// Mixed Signedness Test
// i32 + u32 and other mixed operations

pub fn main(argc: i32) -> i32 {
    // Test 1: i32 + u32 (both positive)
    let signed_val: i32 = 100;
    let unsigned_val: u32 = 50;
    let sum = signed_val + (unsigned_val as i32);
    if sum == 150 {
        println("PASS: 100i32 + 50u32 = 150");
    } else {
        println(f"FAIL: 100 + 50 = {sum as i64}");
        return 1;
    }
    
    // Test 2: Comparison i32 vs u32
    let small_signed: i32 = 10;
    let big_unsigned: u32 = 20;
    if small_signed < (big_unsigned as i32) {
        println("PASS: 10i32 < 20u32");
    } else {
        println("FAIL: 10 >= 20");
        return 2;
    }
    
    // Test 3: Negative i32 compared to u32 (tricky!)
    let negative: i32 = -1;
    let positive: u32 = 1;
    // When comparing, we need to be explicit about which conversion
    // -1i32 as u32 would be a huge number, so compare as i32
    if negative < (positive as i32) {
        println("PASS: -1i32 < 1u32 (as i32)");
    } else {
        println("FAIL: -1 >= 1");
        return 3;
    }
    
    println("All mixed signedness tests passed!");
    return 0;
}
