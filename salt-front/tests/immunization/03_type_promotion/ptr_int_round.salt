// Pointer-Integer Round Trip Test
// ptr → usize → ptr must preserve the address

extern fn malloc_shim(size: usize) -> !llvm.ptr;

pub fn main(argc: i32) -> i32 {
    // Allocate some memory and get its address
    let original_ptr = malloc_shim(64);
    
    // Store a value there
    *(original_ptr as &mut i64) = 0xDEADBEEF;
    
    // Convert to integer
    let addr_int: i64 = original_ptr as i64;
    println(f"Address as int: {addr_int}");
    
    // Convert back to pointer
    let recovered_ptr = addr_int as !llvm.ptr;
    
    // Read value through recovered pointer
    let val = *(recovered_ptr as &i64);
    if val == 0xDEADBEEF {
        println("PASS: Value preserved through round-trip");
    } else {
        println(f"FAIL: Value corrupted, got {val}");
        return 1;
    }
    
    // Pointer comparison after round-trip
    if original_ptr == recovered_ptr {
        println("PASS: Pointer equality after round-trip");
    } else {
        println("FAIL: Pointers differ after round-trip");
        return 2;
    }
    
    // Test with usize (native pointer width)
    let addr_usize: usize = original_ptr as usize;
    let recovered2 = addr_usize as !llvm.ptr;
    if original_ptr == recovered2 {
        println("PASS: usize round-trip preserved pointer");
    } else {
        println("FAIL: usize round-trip changed pointer");
        return 3;
    }
    
    println("All pointer round-trip tests passed!");
    return 0;
}
