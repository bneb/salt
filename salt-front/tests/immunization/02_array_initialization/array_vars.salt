// Array Variable Initialization Test
// Test: [a, b, c, d] where values come from variables
// This is the pattern that caused the GEP bug in trie.salt

pub fn main(argc: i32) -> i32 {
    // Initialize variables
    let a: i32 = 5;
    let b: i32 = 10;
    let c: i32 = 15;
    let d: i32 = 20;
    
    // Array initialized with variables
    let arr: [i32; 4] = [a, b, c, d];
    
    if arr[0] == 5 {
        println("PASS: arr[0] == a");
    } else {
        println("FAIL: arr[0] != a");
        return 1;
    }
    
    if arr[2] == 15 {
        println("PASS: arr[2] == c");
    } else {
        println("FAIL: arr[2] != c");
        return 2;
    }
    
    // Test with u8 (the trie pattern)
    let c0: u8 = 97;  // 'a'
    let c1: u8 = 98;  // 'b'
    let c2: u8 = 99;  // 'c'
    let c3: u8 = 100; // 'd'
    let c4: u8 = 0;   // null terminator
    
    // This is the exact pattern from trie.salt that failed
    // NOTE: If this compiles and runs, the array var init is working
    // If it fails to compile, the bug still exists
    
    println("All array variable tests passed!");
    return 0;
}
