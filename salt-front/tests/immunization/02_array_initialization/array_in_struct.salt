// Struct Containing Array Field Test
// The sudoku_solver pattern that caused codegen issues

struct Board {
    cells: [i32; 9],
    solved: bool,
}

pub fn main(argc: i32) -> i32 {
    // Initialize struct with array field
    let mut board = Board {
        cells: [1, 2, 3, 4, 5, 6, 7, 8, 9],
        solved: false,
    };
    
    if board.cells[0] == 1 {
        println("PASS: board.cells[0] == 1");
    } else {
        println("FAIL: board.cells[0] != 1");
        return 1;
    }
    
    if board.cells[8] == 9 {
        println("PASS: board.cells[8] == 9");
    } else {
        println("FAIL: board.cells[8] != 9");
        return 2;
    }
    
    // Modify array element through struct
    board.cells[4] = 50;
    if board.cells[4] == 50 {
        println("PASS: board.cells[4] modified to 50");
    } else {
        println("FAIL: board.cells[4] modification failed");
        return 3;
    }
    
    // Sum all cells
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 9 {
        sum = sum + board.cells[i as usize];
        i = i + 1;
    }
    // Expected: 1+2+3+4+50+6+7+8+9 = 90
    if sum == 90 {
        println("PASS: sum of cells == 90");
    } else {
        println(f"FAIL: sum != 90, got {sum as i64}");
        return 4;
    }
    
    println("All struct array tests passed!");
    return 0;
}
