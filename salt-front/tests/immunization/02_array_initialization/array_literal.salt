// Array Literal Initialization Test
// Test: [1, 2, 3, 4] constant literal values

pub fn main(argc: i32) -> i32 {
    // Basic i32 array literal
    let arr_i32: [i32; 4] = [10, 20, 30, 40];
    
    if arr_i32[0] == 10 {
        println("PASS: arr_i32[0] == 10");
    } else {
        println("FAIL: arr_i32[0] != 10");
        return 1;
    }
    
    if arr_i32[3] == 40 {
        println("PASS: arr_i32[3] == 40");
    } else {
        println("FAIL: arr_i32[3] != 40");
        return 2;
    }
    
    // Sum all elements
    let sum = arr_i32[0] + arr_i32[1] + arr_i32[2] + arr_i32[3];
    if sum == 100 {
        println("PASS: sum == 100");
    } else {
        println(f"FAIL: sum != 100, got {sum as i64}");
        return 3;
    }
    
    println("All array literal tests passed!");
    return 0;
}
