// Multi-dimensional Array Test
// Forces GEP logic to handle recursive indexing

pub fn main(argc: i32) -> i32 {
    // 2D array: 2x3 grid
    let grid: [[i32; 3]; 2] = [[1, 2, 3], [4, 5, 6]];
    
    // Access first row
    if grid[0][0] == 1 {
        println("PASS: grid[0][0] == 1");
    } else {
        println("FAIL: grid[0][0] != 1");
        return 1;
    }
    
    if grid[0][2] == 3 {
        println("PASS: grid[0][2] == 3");
    } else {
        println("FAIL: grid[0][2] != 3");
        return 2;
    }
    
    // Access second row
    if grid[1][0] == 4 {
        println("PASS: grid[1][0] == 4");
    } else {
        println("FAIL: grid[1][0] != 4");
        return 3;
    }
    
    if grid[1][2] == 6 {
        println("PASS: grid[1][2] == 6");
    } else {
        println("FAIL: grid[1][2] != 6");
        return 4;
    }
    
    // Sum entire grid
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 2 {
        let mut j: i32 = 0;
        while j < 3 {
            sum = sum + grid[i as usize][j as usize];
            j = j + 1;
        }
        i = i + 1;
    }
    // Expected: 1+2+3+4+5+6 = 21
    if sum == 21 {
        println("PASS: grid sum == 21");
    } else {
        println(f"FAIL: grid sum != 21, got {sum as i64}");
        return 5;
    }
    
    println("All multidim array tests passed!");
    return 0;
}
