// Shadow Outer Variable Test
// Variable defined outside, shadowed inside loop

pub fn main(argc: i32) -> i32 {
    // Outer variable
    let outer_i: i32 = 999;
    
    // Loop that shadows with its own i
    let mut sum: i64 = 0;
    let mut i: i32 = 0;
    while i < 5 {
        // This i is loop-local, not the same as outer_i
        sum = sum + (i as i64);
        i = i + 1;
    }
    
    // outer_i should be unchanged
    if outer_i == 999 {
        println("PASS: outer_i unchanged = 999");
    } else {
        println(f"FAIL: outer_i = {outer_i as i64} (should be 999)");
        return 1;
    }
    
    // sum should be 0+1+2+3+4 = 10
    if sum == 10 {
        println("PASS: loop sum = 10");
    } else {
        println(f"FAIL: loop sum = {sum}");
        return 2;
    }
    
    // Block-scoped shadowing
    let x: i32 = 100;
    {
        let x: i32 = 200;  // Shadow in block
        if x == 200 {
            println("PASS: inner block x = 200");
        } else {
            println(f"FAIL: inner x = {x as i64}");
            return 3;
        }
    }
    if x == 100 {
        println("PASS: outer x = 100 after block");
    } else {
        println(f"FAIL: outer x = {x as i64}");
        return 4;
    }
    
    println("All shadow tests passed!");
    return 0;
}
