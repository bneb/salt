// For Inside While Test
// Mixing loop types

pub fn main(argc: i32) -> i32 {
    let mut outer_count: i64 = 0;
    let mut inner_total: i64 = 0;
    
    // While loop containing a pattern similar to for
    let mut w: usize = 0;
    while w < 3 {
        outer_count = outer_count + 1;
        
        // Inner "for-like" loop
        let mut f: usize = 0;
        while f < 4 {
            inner_total = inner_total + 1;
            f = f + 1;
        }
        
        w = w + 1;
    }
    
    if outer_count == 3 {
        println("PASS: outer ran 3 times");
    } else {
        println(f"FAIL: outer = {outer_count}");
        return 1;
    }
    
    if inner_total == 12 {
        println("PASS: inner total = 12");
    } else {
        println(f"FAIL: inner total = {inner_total}");
        return 2;
    }
    
    println("All for-in-while tests passed!");
    return 0;
}
