// Nested Loops Test
// for/while nested inside another for/while

pub fn main(argc: i32) -> i32 {
    let mut total: i64 = 0;
    
    // Nested while loops with different variables
    let mut i: usize = 0;
    while i < 3 {
        let mut j: usize = 0;
        while j < 4 {
            total = total + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    
    // Expected: 3 * 4 = 12
    if total == 12 {
        println("PASS: nested loops 3x4 = 12");
    } else {
        println(f"FAIL: nested loops = {total}");
        return 1;
    }
    
    // Triple-nested
    let mut count: i64 = 0;
    let mut x: usize = 0;
    while x < 2 {
        let mut y: usize = 0;
        while y < 3 {
            let mut z: usize = 0;
            while z < 4 {
                count = count + 1;
                z = z + 1;
            }
            y = y + 1;
        }
        x = x + 1;
    }
    
    // Expected: 2 * 3 * 4 = 24
    if count == 24 {
        println("PASS: triple nested 2x3x4 = 24");
    } else {
        println(f"FAIL: triple nested = {count}");
        return 2;
    }
    
    println("All nested loop tests passed!");
    return 0;
}
