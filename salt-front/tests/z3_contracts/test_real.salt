// Z3 Contract Test: Real (exact rational) contracts
// Expected: PASS — Z3 proves float contracts with exact rational semantics
package main

// Integer-valued floats only — Z3's Real theory can timeout on
// decimal literals (FAQ: float theory is incomplete).
pub fn gt_three(x: f64) -> f64
    requires(x > 3.0)
{ return x; }

pub fn eq_one(x: f64) -> f64
    requires(x == 1.0)
{ return x; }

pub fn int_ge(x: f64) -> f64
    requires(x >= 0.0)
{ return x; }

pub fn main() -> i32 {
    let _a = gt_three(4.0);
    let _b = eq_one(1.0);
    let _c = int_ge(0.0);
    return 0;
}
