// Sequential slice writes inside a while loop.
// The invariant off >= 0 and guard off < buf.len() discharge both
// of set()'s requires clauses (index >= 0, index < self.len).
package test_slice_cursor_proved

import std.core.slice
import std.core.ptr.Ptr

fn fill(buf: Slice<u8>, v: u8) {
    let mut off: i64 = 0;
    while off < buf.len() {
        invariant off >= 0;
        buf.set(off, v);
        off = off + 1;
    }
}

pub fn main() -> i32 {
    let buf = Slice::new(0 as Ptr<u8>, 100);
    fill(buf, 0 as u8);
    return 0;
}
