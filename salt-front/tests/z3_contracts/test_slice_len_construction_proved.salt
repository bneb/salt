// Slice construction length propagates to .len() in contracts.
// Slice::new(p, 100) records known_slice_lengths["buf"] = 100,
// so needs_len()'s requires buf.len() == 100 resolves at compile time.
package test_slice_len_construction_proved

import std.core.slice
import std.core.ptr.Ptr

fn needs_len(buf: Slice<u8>) -> i32
    requires buf.len() == 100;
{
    return 0;
}

pub fn main() -> i32 {
    let buf = Slice::new(0 as Ptr<u8>, 100);
    return needs_len(buf);
}
