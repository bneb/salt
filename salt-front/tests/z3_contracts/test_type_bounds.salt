// Z3 Contract Test: Type-bound proofs
// These contracts are provable ONLY because Z3 knows the type bounds.
// Without type bounds, they'd be runtime assertions.
package main

// u8 ∈ [0, 255] — Z3 knows this from the type
pub fn check_u8(x: u8) -> i32
    requires(x < 256)          // Always true for u8
    requires(x >= 0)            // Always true for u8
{ return x as i32; }

// bool ∈ {0, 1}
pub fn check_bool(b: bool) -> i32
    requires(b == 0 || b == 1)  // Always true for bool
{ return b as i32; }

// u16 ∈ [0, 65535]
pub fn check_u16_lt(x: u16) -> i32
    requires(x < 65536)         // Always true for u16
{ return x as i32; }

// Combined: u8 with an array-like bound
pub fn index_u8(idx: u8) -> i32
    requires(idx < 256)         // Always true for u8
    requires(idx >= 0)           // Always true for u8
{ return idx as i32; }

// Call sites with variable (non-constant) arguments.
// These would be runtime assertions without type bounds,
// but Z3 proves them at compile time because the types
// imply the contracts.
pub fn main() -> i32 {
    let a: u8 = 42;
    let b: bool = true;
    let c: u16 = 1000;
    let d: u8 = 200;

    return check_u8(a) + check_bool(b) + check_u16_lt(c) + index_u8(d);
}
