// Z3 Contract Test: Forall + For-Loop Invariants with Inductive Step
//
// Tests:
//   1. Constant-bound forall in ensures (conjunction expansion)
//   2. Symbolic forall in requires (Z3 ForAll)
//   3. For-loop invariant base case + inductive step (i >= 1)
//   4. While-loop invariant (full verification)

package basalt.test_insertion_sort

// Test 1: Constant-bound forall — conjunction expansion, Z3-proven
fn make_sorted(arr: Ptr<i32>)
    ensures forall i in 0..3 => arr[i] <= arr[i+1]
{
    unsafe {
        arr[0] = 1; arr[1] = 2; arr[2] = 3; arr[3] = 4;
    }
}

// Test 2: Symbolic forall in requires — Z3 ForAll quantifier
fn check_sorted(arr: Ptr<i32>, n: i64)
    requires forall i in 0..(n-1) => arr[i] <= arr[i+1]
    requires n > 0
{
    return;
}

// Test 3: For-loop invariant with inductive step
// Proves that i stays within bounds throughout the loop.
fn count_up(n: i64) -> i64
    requires n >= 0
{
    let mut sum: i64 = 0;
    for i in 0..n {
        invariant i >= 0;
        sum = sum + i;
    }
    return sum;
}

fn main() -> i32 {
    return 0;
}
