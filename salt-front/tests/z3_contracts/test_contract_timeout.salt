// =============================================================================
// Z3 Regression Test: COMPLEX CONTRACT — TIMEOUT → RUNTIME FALLBACK
// =============================================================================
// Expected: Z3 cannot determine satisfiability within 100ms → runtime assertion
// If this produces a compile error: Z3 timeout handling is broken
// If this succeeds silently: Z3 is proving a complex constraint (unexpected pass)
//
// Run with: salt-front --verify test_contract_timeout.salt
// Expected output: compiler emits runtime assertion (scf.if fallback), not error
// =============================================================================

package test_contract_timeout

// A non-linear constraint involving multiplication and bitwise operations.
// Z3 may succeed or time out depending on the solver state — the key behavior
// is that the compiler gracefully handles either outcome.
fn complex_operation(x: i32, y: i32) -> i32
    requires(x * x + y * y > 0)
{
    return (x * y) / (x * x + y * y);
}

pub fn main() -> i32 {
    let result = complex_operation(3, 4);
    return result;
}
