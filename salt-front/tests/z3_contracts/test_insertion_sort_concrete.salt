// Z3 Contract Test: Forall Ensures at Concrete Call Site
//
// Proves that when a function with 'ensures forall' is called with
// concrete array arguments, Z3 unrolls the forall into individual
// element assertions and verifies them against the function body.
//
// Distinction from test_insertion_sort.salt: that test defines
// make_sorted but never calls it — the ensures is checked only at
// the definition site (0 checks). Here, the concrete call triggers
// the full expansion path: 3 element comparisons, 3 Z3 proofs.

package basalt.test_isort_conc

fn make_sorted_4(arr: Ptr<i32>)
    ensures forall i in 0..3 => arr[i] <= arr[i+1]
{
    unsafe {
        arr[0] = 10;
        arr[1] = 20;
        arr[2] = 30;
        arr[3] = 40;
    }
}

fn main() -> i32 {
    unsafe {
        let mut data: [i32; 4] = [0, 0, 0, 0];
        make_sorted_4(&data as Ptr<i32>);
    }
    return 0;
}
