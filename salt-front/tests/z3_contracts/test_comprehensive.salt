// Z3 Contract Comprehensive Tests — all contract types that MUST prove.
// Run: saltc test_comprehensive.salt --lib --disable-alias-scopes -o /dev/null
// Expected: PASS (compiles successfully, all contracts proved)
package main
use std.core.str.StringView
use std.core.result.Result

// === Integer bounds ===
pub fn bounded_add(a: i32, b: i32) -> i32
    requires(a >= 0 && a <= 10 && b >= 0 && b <= 10)
    ensures(result >= 0 && result <= 20)
{ return a + b; }

// === Division safety ===
pub fn safe_div(a: i32, b: i32) -> i32
    requires(b != 0)
{ return a / b; }

// === Multiplication ===
pub fn mul_both_positive(a: i32, b: i32) -> i32
    requires(a > 0 && b > 0)
    ensures(result > 0)
{ return a * b; }

pub fn mul_bounded(a: i32, b: i32) -> i32
    requires(a >= 0 && a <= 10 && b >= 0 && b <= 10)
    ensures(result >= 0 && result <= 100)
{ return a * b; }

// === Float literal (skip: Z3 Real theory incomplete for != 0.0) ===
// pub fn safe_fdiv(a: f64, b: f64) -> f64
//     requires(b != 0.0)
// { return a / b; }

// === Postconditions across branches ===
pub fn my_abs(x: i32) -> i32
    ensures(result >= 0)
{ if x < 0 { return -x; } return x; }

pub fn clamp(val: i32, lo: i32, hi: i32) -> i32
    requires(lo <= hi)
    ensures(result >= lo && result <= hi)
{ if val < lo { return lo; } if val > hi { return hi; } return val; }

// === Bitwise ===
pub fn mask_byte(x: i32) -> i32
    requires(x >= 0 && x <= 255)
    ensures(result >= 0 && result <= 255)
{ return x & 0xFF; }

// === String length (constant-folded by fold_constants) ===
pub fn require_nonempty(key: StringView) -> i32
    requires(key.length() > 0)
{ return key.length() as i32; }

// === Call sites with constant arguments ===
pub fn main() -> i32 {
    let _a = bounded_add(5, 3);
    let _b = safe_div(100, 7);
    let _c = mul_both_positive(3, 4);
    let _d = mul_bounded(5, 8);
    let _f = my_abs(-42);
    let _g = clamp(150, 0, 100);
    let _h = mask_byte(128);
    let _i = require_nonempty("hello");
    return 0;
}
