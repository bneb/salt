// Z3 Contract Test: String contracts that MUST be rejected
// Expected: FAIL (Z3 finds counterexamples for these violations)
package main
use std.core.str.StringView

pub fn require_nonempty(key: StringView) -> i32
    requires(key.length() > 0)
{ return key.length() as i32; }

pub fn require_bounded(key: StringView) -> i32
    requires(key.length() > 0 && key.length() <= 5)
{ return key.length() as i32; }

pub fn main() -> i32 {
    // These should FAIL: empty string violates requires(key.length() > 0)
    let _a = require_nonempty("");
    // "too-long" has length 8, violates requires(key.length() <= 5)
    let _b = require_bounded("too-long");
    return 0;
}
