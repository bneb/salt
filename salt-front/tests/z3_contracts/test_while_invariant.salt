// Z3 Contract Test: while-loop array access with invariant
// Expected: PASS — invariant proves array bounds safety
package test_while_invariant

import std.core.result

fn search(arr: &[i64; 5], target: i64) -> Result<i64>
{
    let mut i: i64 = 0;
    while i < 5 {
        invariant i >= 0 && i < 5;
        if arr[i] == target { return Result::Ok(i); }
        i = i + 1;
    }
    return Result::Err(Status::from_code(5));
}

pub fn main() -> i32 {
    let data: [i64; 5] = [1, 3, 5, 7, 9];
    match search(&data, 5) {
        Result::Ok(idx) => { return idx as i32; }
        Result::Err(_) => { return -1; }
    }
}
