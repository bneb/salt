// Z3 Contract Test: ensures forall proved against body array writes
//
// The function writes literal values to arr, and the ensures
// forall is checked against those stores via the postcondition solver.
// Requires an explicit return to trigger verify_postcondition.

package basalt.test_ens_body

fn fill_sorted(arr: Ptr<i32>) -> i32
    ensures forall i in 0..3 => arr[i] <= arr[i+1]
{
    unsafe {
        arr[0] = 10;
        arr[1] = 20;
        arr[2] = 30;
        arr[3] = 40;
    }
    return 0;
}

fn fill_all_ones(arr: Ptr<i32>) -> i32
    ensures forall i in 0..4 => arr[i] == 1
{
    unsafe {
        arr[0] = 1;
        arr[1] = 1;
        arr[2] = 1;
        arr[3] = 1;
    }
    return 0;
}

fn main() -> i32 {
    return 0;
}
