// Pulse Test - V2.0 Migration
// Tests @yielding function-level attribute behavior

fn test_break_continue() {
    let mut i: i32 = 0;
    while i < 10 {
        i = i + 1;
        if i == 5 {
            continue;
        }
        if i == 8 {
            break;
        }
    }
}

// Test different pulse values via function-level @yielding
@yielding(512)
fn test_fast_pulse() {
    while true { break; }
}

@yielding(2048)
fn test_normal_pulse() {
    while true { break; }
}

@yielding(8192)
fn test_slow_pulse() {
    while true { break; }
}

fn main() {
    test_break_continue();
    test_fast_pulse();
    test_normal_pulse();
    test_slow_pulse();
}
