# Lattice Project — EditorConfig
# https://editorconfig.org
# Ensures consistent indentation, whitespace, and line endings across editors.

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.salt]
indent_style = space
indent_size = 4
max_line_length = 120

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{sh,bash}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{md,rst}]
trim_trailing_whitespace = false

[*.{c,h,cpp,hpp}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2
